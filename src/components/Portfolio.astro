---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="portfolio" class="py-20 bg-gray-50">
  <div class="max-w-5xl mx-auto px-4">
    <h2 data-animate class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">{t.portfolio.title}</h2>
    <p data-animate style="transition-delay: 80ms" class="text-gray-500 mb-12">{t.portfolio.subtitle}</p>
    <div data-stagger class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
      {t.portfolio.items.map((item) => (
        <a
          href={item.link}
          target={item.link !== "#" ? "_blank" : undefined}
          rel={item.link !== "#" ? "noopener noreferrer" : undefined}
          class="group block p-4 bg-white border border-gray-200 rounded-2xl hover:border-indigo-300 hover:shadow-sm transition-all"
        >
          <div class="w-full h-36 rounded-xl mb-4 overflow-hidden bg-gradient-to-br from-indigo-50 to-indigo-100">
            {item.image && (
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover"
              />
            )}
          </div>
          <h3 class="font-semibold text-gray-900 mb-1.5 group-hover:text-indigo-600 transition-colors">
            {item.title}
          </h3>
          <p class="text-sm text-gray-500 mb-3 leading-relaxed">{item.description}</p>
          {item.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {item.tags.map((tag) => (
                <span class="px-2 py-0.5 bg-indigo-50 text-indigo-600 text-xs rounded-md font-medium">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </div>
</section>

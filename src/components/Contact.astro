---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="py-20">
  <div class="max-w-5xl mx-auto px-4">
    <h2 data-animate class="text-3xl md:text-4xl font-bold text-(--text-primary) mb-3">{t.contact.title}</h2>
    <p data-animate style="transition-delay: 80ms" class="text-(--text-secondary) mb-10">{t.contact.subtitle}</p>

    <form
      id="contact-form"
      data-animate
      style="transition-delay: 120ms"
      class="max-w-xl space-y-5"
      aria-label={lang === "hu" ? "Kapcsolatfelvételi űrlap" : "Contact form"}
      novalidate
    >
      <div>
        <label for="name" class="block text-sm font-medium text-(--text-secondary) mb-1.5">
          {t.contact.name}<span aria-hidden="true" class="text-(--accent) ml-0.5">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          aria-required="true"
          autocomplete="name"
          placeholder={t.contact.namePlaceholder}
          class="w-full px-4 py-3 bg-white dark:bg-(--bg-surface) border border-(--border-subtle)
                 text-(--text-primary) rounded-md
                 focus:outline-none focus:border-(--accent)
                 transition placeholder-gray-400 dark:placeholder-gray-600"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-(--text-secondary) mb-1.5">
          {t.contact.email}<span aria-hidden="true" class="text-(--accent) ml-0.5">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          aria-required="true"
          autocomplete="email"
          placeholder={t.contact.emailPlaceholder}
          class="w-full px-4 py-3 bg-white dark:bg-(--bg-surface) border border-(--border-subtle)
                 text-(--text-primary) rounded-md
                 focus:outline-none focus:border-(--accent)
                 transition placeholder-gray-400 dark:placeholder-gray-600"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-(--text-secondary) mb-1.5">
          {t.contact.message}<span aria-hidden="true" class="text-(--accent) ml-0.5">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          required
          aria-required="true"
          rows={5}
          placeholder={t.contact.messagePlaceholder}
          class="w-full px-4 py-3 bg-white dark:bg-(--bg-surface) border border-(--border-subtle)
                 text-(--text-primary) rounded-md
                 focus:outline-none focus:border-(--accent)
                 transition placeholder-gray-400 dark:placeholder-gray-600 resize-none"
        ></textarea>
      </div>
      <div class="flex flex-col sm:flex-row sm:items-stretch gap-3 pt-1">
        <button
          type="submit"
          disabled
          aria-disabled="true"
          aria-describedby="submit-hint"
          class="px-6 py-3 bg-(--accent) text-white rounded-md font-medium opacity-50 cursor-not-allowed"
        >
          {t.contact.send}
        </button>
        <span id="submit-hint" class="sr-only">{lang === "hu" ? "Hamarosan elérhető" : "Coming soon"}</span>
        <span class="hidden sm:flex items-center text-gray-300 dark:text-gray-600 text-sm select-none">—</span>
        <span class="text-sm text-(--text-tertiary) sm:hidden">{t.contact.orEmail}</span>
        <a
          id="email-copy-btn"
          data-e="yriragrynyqbe@tznvy.pbz"
          href="#"
          class="inline-flex items-center gap-2 px-4 py-3 border border-(--border-subtle)
                 rounded-md text-sm font-medium text-(--text-secondary)
                 hover:border-(--accent) hover:text-(--accent)
                 transition-all duration-200 group self-start sm:self-auto"
          aria-label="Email cím másolása"
        >
          <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          <span id="email-display" class="font-mono">leventekaldor@gmail.com</span>
          <svg class="w-3.5 h-3.5 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity duration-150" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
            <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
          </svg>
        </a>
      </div>
    </form>
  </div>
</section>

<!-- Email copy toast -->
<div
  id="email-toast"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 px-4 py-2
         bg-gray-900 dark:bg-white text-white dark:text-gray-900
         text-sm rounded-md shadow-lg
         opacity-0 translate-y-2
         transition-all duration-300 pointer-events-none z-100"
>
  {lang === "hu" ? "Vágólapra másolva!" : "Copied to clipboard!"}
</div>

<!-- Contact form success toast -->
<div
  id="contact-toast"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 px-5 py-3
         bg-gray-900 dark:bg-white text-white dark:text-gray-900
         text-sm rounded-md shadow-lg
         opacity-0 translate-y-2
         transition-all duration-300 pointer-events-none z-100"
>
  {lang === "hu" ? "Üzeneted megérkezett! Hamarosan visszajelzek." : "Message received! I'll get back to you soon."}
</div>

<script>
  // Contact form submission
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const contactToast = document.getElementById('contact-toast');
  const lang = submitBtn?.dataset.lang ?? 'hu';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }

    const originalText = submitBtn!.textContent ?? '';
    submitBtn!.disabled = true;
    submitBtn!.textContent = lang === 'hu' ? 'Küldés...' : 'Sending...';

    const fd = new FormData(form);
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: fd.get('name'),
          email: fd.get('email'),
          message: fd.get('message'),
          lang,
        }),
      });

      if (res.ok) {
        form.reset();
        if (contactToast) {
          contactToast.classList.remove('opacity-0', 'translate-y-2');
          setTimeout(() => contactToast.classList.add('opacity-0', 'translate-y-2'), 5000);
        }
        submitBtn!.textContent = originalText;
      } else {
        submitBtn!.textContent = lang === 'hu' ? 'Hiba – próbáld újra' : 'Error – try again';
        setTimeout(() => { submitBtn!.textContent = originalText; }, 3000);
      }
    } catch {
      submitBtn!.textContent = lang === 'hu' ? 'Hiba – próbáld újra' : 'Error – try again';
      setTimeout(() => { submitBtn!.textContent = originalText; }, 3000);
    } finally {
      submitBtn!.disabled = false;
    }
  });
</script>

<script>
  function rot13(s: string): string {
    return s.replace(/[a-zA-Z]/g, (c) =>
      String.fromCharCode(c.charCodeAt(0) + (c.toLowerCase() < "n" ? 13 : -13))
    );
  }

  const btn   = document.getElementById("email-copy-btn") as HTMLAnchorElement | null;
  const toast = document.getElementById("email-toast");

  if (btn) {
    const email = rot13((btn as HTMLElement).dataset.e ?? "");
    const display = document.getElementById("email-display");
    if (display) display.textContent = email;
    const isMobile = () => window.matchMedia("(pointer: coarse)").matches;
    btn.href = isMobile() ? `mailto:${email}` : "#";

    let toastTimer: ReturnType<typeof setTimeout>;
    btn.addEventListener("click", async (e: Event) => {
      if (isMobile()) return;
      e.preventDefault();
      try {
        await navigator.clipboard.writeText(email);
        if (toast) {
          toast.classList.remove("opacity-0", "translate-y-2");
          clearTimeout(toastTimer);
          toastTimer = setTimeout(() => {
            toast.classList.add("opacity-0", "translate-y-2");
          }, 2000);
        }
      } catch {
        // clipboard nem elérhető – mailto fallback fut
      }
    });
  }
</script>

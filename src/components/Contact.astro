---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="py-20">
  <div class="max-w-5xl mx-auto px-4">
    <h2 data-animate class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">{t.contact.title}</h2>
    <p data-animate style="transition-delay: 80ms" class="text-gray-500 mb-12">{t.contact.subtitle}</p>
    <form
      id="contact-form"
      data-animate
      style="transition-delay: 160ms"
      class="max-w-xl space-y-5"
      novalidate
    >
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">
          {t.contact.name}
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder={t.contact.namePlaceholder}
          class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition placeholder-gray-400"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
          {t.contact.email}
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder={t.contact.emailPlaceholder}
          class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition placeholder-gray-400"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">
          {t.contact.message}
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows={5}
          placeholder={t.contact.messagePlaceholder}
          class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition placeholder-gray-400 resize-none"
        ></textarea>
      </div>
      <button
        type="submit"
        disabled
        title="Hamarosan elérhető"
        class="px-6 py-3 bg-indigo-600 text-white rounded-xl font-medium opacity-50 cursor-not-allowed"
      >
        {t.contact.send}
      </button>
    </form>
  </div>
</section>

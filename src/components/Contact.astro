---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="py-20">
  <div class="max-w-5xl mx-auto px-4">
    <h2 data-animate class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-3">{t.contact.title}</h2>
    <p data-animate style="transition-delay: 80ms" class="text-gray-500 dark:text-gray-400 mb-10">{t.contact.subtitle}</p>

    <!-- Email copy gomb -->
    <div data-animate style="transition-delay: 120ms" class="mb-12">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">{t.contact.orEmail}</p>
      <button
        id="email-copy-btn"
        data-e="yriragrynyqbe@tznvy.pbz"
        class="inline-flex items-center gap-2 px-4 py-2.5 border border-gray-200 dark:border-gray-700
               rounded-xl text-sm font-medium text-gray-700 dark:text-gray-300
               hover:border-indigo-400 hover:text-indigo-600
               dark:hover:border-indigo-500 dark:hover:text-indigo-400
               transition-all duration-200 group"
        aria-label="Email cím másolása"
      >
        <!-- Mail icon -->
        <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        <span id="email-display" class="font-mono">leventekaldor@gmail.com</span>
        <!-- Copy icon -->
        <svg class="w-3.5 h-3.5 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity duration-150" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
        </svg>
      </button>
    </div>

    <form
      id="contact-form"
      data-animate
      style="transition-delay: 200ms"
      class="max-w-xl space-y-5"
      novalidate
    >
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">
          {t.contact.name}
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder={t.contact.namePlaceholder}
          class="w-full px-4 py-3 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700
                 text-gray-900 dark:text-white rounded-xl
                 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent
                 transition placeholder-gray-400 dark:placeholder-gray-600"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">
          {t.contact.email}
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder={t.contact.emailPlaceholder}
          class="w-full px-4 py-3 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700
                 text-gray-900 dark:text-white rounded-xl
                 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent
                 transition placeholder-gray-400 dark:placeholder-gray-600"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">
          {t.contact.message}
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows={5}
          placeholder={t.contact.messagePlaceholder}
          class="w-full px-4 py-3 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700
                 text-gray-900 dark:text-white rounded-xl
                 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent
                 transition placeholder-gray-400 dark:placeholder-gray-600 resize-none"
        ></textarea>
      </div>
      <button
        type="submit"
        disabled
        title="Hamarosan elérhető"
        class="px-6 py-3 bg-indigo-600 text-white rounded-xl font-medium opacity-50 cursor-not-allowed"
      >
        {t.contact.send}
      </button>
    </form>
  </div>
</section>

<!-- Toast -->
<div
  id="email-toast"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 px-4 py-2
         bg-gray-900 dark:bg-white text-white dark:text-gray-900
         text-sm rounded-xl shadow-lg
         opacity-0 translate-y-2
         transition-all duration-300 pointer-events-none z-100"
>
  {lang === "hu" ? "Vágólapra másolva!" : "Copied to clipboard!"}
</div>

<script>
  function rot13(s: string): string {
    return s.replace(/[a-zA-Z]/g, (c) =>
      String.fromCharCode(c.charCodeAt(0) + (c.toLowerCase() < "n" ? 13 : -13))
    );
  }

  const btn   = document.getElementById("email-copy-btn") as HTMLButtonElement | null;
  const toast = document.getElementById("email-toast");

  if (btn) {
    const email = rot13((btn as HTMLElement).dataset.e ?? "");
    const display = document.getElementById("email-display");
    if (display) display.textContent = email;

    let toastTimer: ReturnType<typeof setTimeout>;
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(email);
        if (toast) {
          toast.classList.remove("opacity-0", "translate-y-2");
          clearTimeout(toastTimer);
          toastTimer = setTimeout(() => {
            toast.classList.add("opacity-0", "translate-y-2");
          }, 2000);
        }
      } catch {
        // clipboard API nem elérhető – fallback: select text
      }
    });
  }
</script>

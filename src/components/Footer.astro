---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";
import { cities } from "../data/cities";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-(--border-subtle)">
  {lang === "hu" && (
    <div class="max-w-5xl mx-auto px-4 pt-5 pb-3">
      <p class="text-[10px] text-(--text-tertiary) text-justify leading-5 opacity-60">
        {cities.map((city, i) => (
          <>
            <a href={`/varos/${city.slug}/`} class="hover:text-(--text-secondary) transition-colors">Honlapkészítés {city.name}</a>{i < cities.length - 1 ? <span class="mx-0.5 opacity-40">·</span> : null}
          </>
        ))}
      </p>
    </div>
  )}
  <div class="max-w-5xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-6">
      <p class="text-sm text-(--text-tertiary)">
        {year} Káldor Levente © {t.footer.rights}
      </p>
      {lang === "hu" && (
        <nav class="flex items-center gap-4 text-xs text-(--text-tertiary)">
          <a href="/impresszum/" class="hover:text-(--text-secondary) transition-colors">Impresszum</a>
          <a href="/adatvedelem/" class="hover:text-(--text-secondary) transition-colors">Adatvédelem</a>
          <a href="/sutik/" class="hover:text-(--text-secondary) transition-colors">Sütik</a>
        </nav>
      )}
      {lang === "en" && (
        <nav class="flex items-center gap-4 text-xs text-(--text-tertiary)">
          <a href="/en/imprint/" class="hover:text-(--text-secondary) transition-colors">Imprint</a>
          <a href="/en/privacy/" class="hover:text-(--text-secondary) transition-colors">Privacy</a>
          <a href="/en/cookies/" class="hover:text-(--text-secondary) transition-colors">Cookies</a>
        </nav>
      )}
    </div>
    <div class="flex items-center gap-5">
      <a
        href="https://github.com/KLeviii"
        target="_blank"
        rel="noopener noreferrer"
        class="text-(--text-tertiary) hover:text-(--text-primary) transition-colors"
        aria-label="GitHub profil"
        title="GitHub"
      >
        <!-- GitHub -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
      </a>
      <button
        id="footer-email-btn"
        data-e="yriragrynyqbe@tznvy.pbz"
        class="text-(--text-tertiary) hover:text-(--text-primary) transition-colors"
        aria-label="Email cím másolása"
        title="Email másolása"
      >
        <!-- Email -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </button>
      <button
        id="footer-phone-btn"
        class="text-(--text-tertiary) hover:text-(--text-primary) transition-colors"
        aria-label="Telefonszám másolása"
        title="Telefonszám másolása"
      >
        <!-- Phone -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/>
        </svg>
      </button>
    </div>
  </div>
</footer>

<script>
  function rot13(s: string): string {
    return s.replace(/[a-zA-Z]/g, (c) =>
      String.fromCharCode(c.charCodeAt(0) + (c.toLowerCase() < "n" ? 13 : -13))
    );
  }

  const btn = document.getElementById("footer-email-btn") as HTMLElement | null;
  const toast = document.getElementById("email-toast");

  function showToast() {
    if (toast) {
      toast.classList.remove("opacity-0", "translate-y-2");
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        toast.classList.add("opacity-0", "translate-y-2");
      }, 2000);
    }
  }

  let toastTimer: ReturnType<typeof setTimeout>;

  if (btn) {
    const email = rot13(btn.dataset.e ?? "");
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(email);
        showToast();
      } catch {
        // clipboard API nem elérhető
      }
    });
  }

  const phoneBtn = document.getElementById("footer-phone-btn");
  if (phoneBtn) {
    phoneBtn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText("+36 30 338 4975");
        showToast();
      } catch {
        // clipboard API nem elérhető
      }
    });
  }
</script>

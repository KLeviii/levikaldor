---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="py-10 border-t border-gray-100 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-gray-400 dark:text-gray-500">
      {year} Káldor Levente © {t.footer.rights}
    </p>
    <div class="flex items-center gap-5">
      <a
        href="https://github.com/KLeviii"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-200 transition-colors text-sm font-medium"
      >
        GitHub
      </a>
      <button
        id="footer-email-btn"
        data-e="yriragrynyqbe@tznvy.pbz"
        class="text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-200 transition-colors text-sm font-medium"
        aria-label="Email cím másolása"
      >
        Email
      </button>
    </div>
  </div>
</footer>

<script>
  function rot13(s: string): string {
    return s.replace(/[a-zA-Z]/g, (c) =>
      String.fromCharCode(c.charCodeAt(0) + (c.toLowerCase() < "n" ? 13 : -13))
    );
  }

  const btn = document.getElementById("footer-email-btn") as HTMLElement | null;
  const toast = document.getElementById("email-toast");

  if (btn) {
    const email = rot13(btn.dataset.e ?? "");
    let toastTimer: ReturnType<typeof setTimeout>;
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(email);
        if (toast) {
          toast.classList.remove("opacity-0", "translate-y-2");
          clearTimeout(toastTimer);
          toastTimer = setTimeout(() => {
            toast.classList.add("opacity-0", "translate-y-2");
          }, 2000);
        }
      } catch {
        // clipboard API nem elérhető
      }
    });
  }
</script>

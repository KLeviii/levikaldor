---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const techStack = [
  { slug: "html5",       label: "HTML 5",       color: "#E34F26" },
  { slug: "css3",        label: "CSS 3",        color: "#663399" },
  { slug: "javascript",  label: "JavaScript",   color: "#F7DF1E" },
  { slug: "typescript",  label: "TypeScript",   color: "#3178C6" },
  { slug: "vuedotjs",    label: "Vue.js",       color: "#4FC08D" },
  { slug: "nuxtdotjs",   label: "Nuxt 3",       color: "#00DC82" },
  { slug: "astro",       label: "Astro",        color: "#BC52EE" },
  { slug: "react",       label: "React",        color: "#61DAFB" },
  { slug: "nodedotjs",   label: "Node.js",      color: "#339933" },
  { slug: "tailwindcss", label: "Tailwind CSS", color: "#06B6D4" },
  { slug: "bootstrap",   label: "Bootstrap 5",  color: "#7952B3" },
  { slug: "supabase",    label: "Supabase",     color: "#3ECF8E" },
  { slug: "sass",        label: "Sass",         color: "#CC6699" },
  { slug: "git",         label: "Git",          color: "#F05032" },
];

---

<section id="about" class="py-20 hex-bg">
  <div class="max-w-5xl mx-auto px-4">
    <h2 data-animate class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-12">{t.about.title}</h2>
    <div class="max-w-2xl">
      <p data-animate class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed mb-5">{t.about.p1}</p>
      <p data-animate style="transition-delay: 100ms" class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed">{t.about.p2}</p>
    </div>
  </div>

  <div data-animate style="transition-delay: 180ms" class="mt-16">
    <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-center mb-8 px-4">
      {t.about.skills}
    </p>

    <!-- Screen reader: statikus lista -->
    <ul class="sr-only">
      {techStack.map(({ label }) => <li>{label}</li>)}
    </ul>

    <!-- Vizuális marquee – dekoratív, screen reader elől rejtve -->
    <div class="marquee-wrapper mb-1" aria-hidden="true">
      <div class="marquee-row">
        <div class="marquee-track" id="track-1">
          {[...techStack, ...techStack, ...techStack].map(({ slug, label, color }) => (
            <div
              class="tech-icon mx-5"
              data-tooltip={label}
              data-color={color}
            >
              <span
                class="icon-mask"
                style={`--icon-color: ${color}; mask-image: url('/icons/${slug}.svg'); -webkit-mask-image: url('/icons/${slug}.svg');`}
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Wrapper: csak vízszintesen vágja le a tartalmat ── */
  .marquee-wrapper {
    overflow: hidden;
  }

  /* ── Sor: padding biztosítja a helyet a scale(1.25)-höz ── */
  .marquee-row {
    /* overflow nem hidden – a wrapper kezeli */
    padding: 10px 0;
  }

  /* ── Futószalag track ── */
  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-left 35s linear infinite;
    will-change: transform;
  }

  /* ── Ikonok ── */
  .tech-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: default;
    /* pointer-events: auto – JS-nek kell az egéresemény */
  }

  /* CSS mask alapú ikon: szín = background-color, forma = SVG maszk */
  .icon-mask {
    display: block;
    width: 40px;
    height: 40px;
    background-color: rgb(156 163 175 / 0.55); /* alapértelmezett szürke */
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    transition:
      background-color 0.25s ease,
      opacity 0.25s ease,
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Sötét módban kicsit fényesebb szürke alap */
  :global(.dark) .icon-mask {
    background-color: rgb(255 255 255 / 0.35);
  }

  /* Aktív (hovered) ikon: megjelenik a márka szín */
  .tech-icon.is-hovered .icon-mask {
    background-color: var(--icon-color) !important;
    opacity: 1 !important;
    transform: scale(1.25);
  }


  /* ── Keyframes – JS állítja be a pixel értéket ── */
  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(var(--marquee-offset, -33.333%)); }
  }
</style>

<script>
  /**
   * Ikonok hover kezelése:
   * – a futószalag CSAK akkor áll meg, ha az egér ténylegesen egy ikonon van
   * – a többi ikon halványodik, az aktív mutatja a márka színét
   */
  document.querySelectorAll<HTMLElement>('.marquee-row').forEach((row) => {
    const track = row.querySelector<HTMLElement>('.marquee-track');
    if (!track) return;

    // Egy szett ikonjainak pontos pixelszélessége (1/3 a track-ből)
    const oneSetWidth = track.scrollWidth / 3;
    track.style.setProperty('--marquee-offset', `-${oneSetWidth}px`);

    const icons = row.querySelectorAll<HTMLElement>('.tech-icon');

    icons.forEach((icon) => {
      icon.addEventListener('mouseenter', () => {
        track.style.animationPlayState = 'paused';
        icon.classList.add('is-hovered');
      });

      icon.addEventListener('mouseleave', () => {
        icon.classList.remove('is-hovered');
        track.style.animationPlayState = 'running';
      });
    });
  });
</script>
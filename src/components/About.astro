---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const skills = ["HTML & CSS", "JavaScript", "TypeScript", "Vue", "Nuxt 3", "Astro", "React", "Node.js", "Tailwind CSS", "Bootstrap 5", "Supabase", "Sass", "Git"];
---

<section id="about" class="py-20 bg-gray-50">
  <div class="max-w-5xl mx-auto px-4">
    <h2 data-animate class="text-3xl md:text-4xl font-bold text-gray-900 mb-12">{t.about.title}</h2>
    <div class="grid md:grid-cols-2 gap-12 items-start">
      <div>
        <p data-animate class="text-gray-600 text-lg leading-relaxed mb-5">{t.about.p1}</p>
        <p data-animate style="transition-delay: 100ms" class="text-gray-600 text-lg leading-relaxed">{t.about.p2}</p>
      </div>
      <div data-animate style="transition-delay: 150ms">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-5">
          {t.about.skills}
        </h3>
        <div class="flex flex-wrap gap-2">
          {skills.map((skill) => (
            <span class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm text-gray-700 font-medium">
              {skill}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

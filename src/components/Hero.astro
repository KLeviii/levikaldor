---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="hero"
  class="relative min-h-screen flex items-center overflow-hidden bg-(--bg-base) dark:bg-(--bg-base)"
>
  <canvas id="constellation-canvas" aria-hidden="true"></canvas>
  <div class="hero-bottom-fade pointer-events-none absolute inset-x-0 bottom-0"></div>

  <div class="relative z-2 max-w-5xl mx-auto px-4 pt-36 pb-24">
    <p data-animate style="transition-delay: 0ms" class="text-xs font-semibold uppercase tracking-[0.12em] text-(--accent) mb-6">
      {t.hero.greeting}
    </p>
    <h1 data-animate style="transition-delay: 120ms" class="text-5xl md:text-7xl font-bold text-(--text-primary) mb-4 leading-[0.95] tracking-[-0.03em]">
      {t.hero.name}
    </h1>
    <p data-animate style="transition-delay: 220ms" class="text-2xl md:text-3xl text-(--text-secondary) font-light mb-6 leading-relaxed">
      {t.hero.tagline}
    </p>
    <p data-animate style="transition-delay: 320ms" class="text-(--text-secondary) max-w-xl text-lg leading-relaxed mb-10">
      {t.hero.description}
    </p>
    <div data-animate style="transition-delay: 420ms" class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
      <a href="#contact" class="flex items-center justify-center px-6 py-3 bg-(--accent) hover:bg-(--accent-bright) active:bg-(--accent-dim) text-white rounded-[6px] font-medium transition-colors">
        {t.hero.cta}
      </a>
      <a href="#portfolio" class="flex items-center justify-center px-6 py-3 border border-(--border-medium) text-(--text-secondary) rounded-[6px] font-medium hover:border-(--accent) hover:text-(--accent) transition-colors">
        {t.hero.cv}
      </a>
    </div>
  </div>
</section>

<style>
  .hero-bottom-fade {
    height: 160px;
    background: linear-gradient(to top, var(--bg-base) 0%, transparent 100%);
  }

  :global(.dark) .hero-bottom-fade {
    height: 280px;
    background: linear-gradient(
      to top,
      #0c0c0c 0%,
      rgba(12, 12, 12, 0.92) 12%,
      rgba(12, 12, 12, 0.72) 30%,
      rgba(12, 12, 12, 0.42) 55%,
      rgba(12, 12, 12, 0.12) 78%,
      transparent 100%
    );
  }
</style>

<script>
  const canvas = document.getElementById("constellation-canvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  const POINT_COUNT = 70;
  const MAX_DIST = 160;
  const SPEED = 0.25;
  const DOT_RADIUS = 1.5;
  const DOT_OPACITY = 0.35;
  const LINE_OPACITY = 0.12;
  const COLOR = "99, 102, 241";

  type Point = { x: number; y: number; vx: number; vy: number };
  let points: Point[] = [];
  let W = 0, H = 0;

  function init() {
    const rect = canvas.parentElement!.getBoundingClientRect();
    W = canvas.width = rect.width;
    H = canvas.height = rect.height;
    points = Array.from({ length: POINT_COUNT }, () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      vx: (Math.random() - 0.5) * SPEED,
      vy: (Math.random() - 0.5) * SPEED,
    }));
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    for (const p of points) {
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0 || p.x > W) p.vx *= -1;
      if (p.y < 0 || p.y > H) p.vy *= -1;
    }
    for (let i = 0; i < points.length; i++) {
      for (let j = i + 1; j < points.length; j++) {
        const dx = points[i].x - points[j].x;
        const dy = points[i].y - points[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < MAX_DIST) {
          ctx.beginPath();
          ctx.strokeStyle = `rgba(${COLOR}, ${LINE_OPACITY * (1 - dist / MAX_DIST)})`;
          ctx.lineWidth = 1;
          ctx.moveTo(points[i].x, points[i].y);
          ctx.lineTo(points[j].x, points[j].y);
          ctx.stroke();
        }
      }
    }
    for (const p of points) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, DOT_RADIUS, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${COLOR}, ${DOT_OPACITY})`;
      ctx.fill();
    }
    requestAnimationFrame(draw);
  }

  let prevW = window.innerWidth;
  init();
  draw();
  window.addEventListener("resize", () => {
    if (window.innerWidth !== prevW) {
      prevW = window.innerWidth;
      init();
    }
  }, { passive: true });
</script>

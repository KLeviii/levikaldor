---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="process" class="py-20">
  <div class="max-w-3xl mx-auto px-4">
    <h2
      data-animate
      class="text-3xl font-bold text-(--text-primary) mb-3"
    >
      {t.process.title}
    </h2>
    <p
      data-animate
      style="transition-delay:80ms"
      class="text-(--text-secondary) mb-12 text-lg"
    >
      {t.process.subtitle}
    </p>

    <ol class="process-list relative">
      {
        t.process.steps.map((step, i) => (
          <li
            data-animate
            style={`transition-delay: ${i * 100}ms`}
            class="flex gap-6 pb-10 last:pb-0 relative"
          >
            <div class="shrink-0 w-12 h-12 rounded-full bg-(--accent) text-(--on-accent) flex items-center justify-center font-bold text-base z-10 shadow-md">
              {step.number}
            </div>
            <div class="pt-2">
              <h3 class="font-semibold text-(--text-primary) mb-1 text-lg">
                {step.title}
              </h3>
              <p class="text-(--text-secondary)">{step.description}</p>
            </div>
            {i < t.process.steps.length - 1 && (
              <div
                class="process-connector"
                style="position:absolute;left:23px;top:48px;bottom:0;width:2px;transform:scaleY(0);transform-origin:top center;transition:transform 0.6s ease;"
              />
            )}
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .process-connector {
    position: absolute;
    left: 23px;
    top: 48px;
    bottom: 0;
    width: 2px;
    background: var(--accent-border);
    transform-origin: top;
    transform: scaleY(0);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .process-connector.visible {
    transform: scaleY(1);
  }

  :global(.dark) .process-connector {
    background: var(--accent-dim);
  }
</style>

<script>
  const list = document.querySelector<HTMLElement>("#process .process-list");
  if (list) {
    const connectors = Array.from(
      list.querySelectorAll<HTMLElement>(".process-connector")
    );

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          connectors.forEach((el, i) => {
            setTimeout(
              () => el.classList.add("visible"),
              (i + 1) * 100
            );
          });
          obs.unobserve(entry.target);
        });
      },
      { threshold: 0.1 }
    );

    obs.observe(list);
  }
</script>

---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === "hu" ? "en" : "hu";
const otherLangHref = lang === "hu" ? "/en/" : "/";
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100">
  <nav class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="#hero" class="font-semibold text-lg text-gray-900 hover:text-indigo-600 transition-colors">
      KL
    </a>

    <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
      <li><a href="#about" class="hover:text-indigo-600 transition-colors">{t.nav.about}</a></li>
      <li><a href="#services" class="hover:text-indigo-600 transition-colors">{t.nav.services}</a></li>
      <li><a href="#portfolio" class="hover:text-indigo-600 transition-colors">{t.nav.portfolio}</a></li>
      <li><a href="#contact" class="hover:text-indigo-600 transition-colors">{t.nav.contact}</a></li>
    </ul>

    <a
      href={otherLangHref}
      class="text-sm font-medium px-3 py-1.5 rounded-lg border border-gray-200 hover:border-indigo-400 hover:text-indigo-600 transition-all"
    >
      {otherLang.toUpperCase()}
    </a>
  </nav>
</header>

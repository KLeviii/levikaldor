---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
  home?: boolean;
}

const { lang, home = false } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === "hu" ? "en" : "hu";
const otherLangHref = lang === "hu" ? "/en/" : "/";
const base = home ? "" : (lang === "hu" ? "/" : "/en/");
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100">
  <nav class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href={base + "#hero"} class="hover:opacity-80 transition-opacity">
      <img src="/favicon.svg" alt="KL" class="w-9 h-9" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
      <li><a href={base + "#about"} class="hover:text-indigo-600 transition-colors">{t.nav.about}</a></li>
      <li><a href={base + "#services"} class="hover:text-indigo-600 transition-colors">{t.nav.services}</a></li>
      <li><a href={base + "#portfolio"} class="hover:text-indigo-600 transition-colors">{t.nav.portfolio}</a></li>
      <li><a href={base + "#contact"} class="hover:text-indigo-600 transition-colors">{t.nav.contact}</a></li>
      <li><a href={lang === "hu" ? "/gyik/" : "/en/faq/"} class="hover:text-indigo-600 transition-colors">{t.nav.faq}</a></li>
    </ul>

    <div class="flex items-center gap-3">
      <a
        href={otherLangHref}
        class="text-sm font-medium px-3 py-1.5 rounded-lg border border-gray-200 hover:border-indigo-400 hover:text-indigo-600 transition-all"
      >
        {otherLang.toUpperCase()}
      </a>

      <!-- Hamburger -->
      <button
        id="menu-toggle"
        class="md:hidden flex flex-col justify-center items-center w-9 h-9 gap-1.5 rounded-lg hover:bg-gray-100 transition-colors"
        aria-label="Menü"
        aria-expanded="false"
      >
        <span class="hamburger-line block w-5 h-0.5 bg-gray-700 transition-all duration-300"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-gray-700 transition-all duration-300"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-gray-700 transition-all duration-300"></span>
      </button>
    </div>
  </nav>
</header>

<!-- Backdrop -->
<div
  id="drawer-backdrop"
  class="fixed inset-0 bg-black/30 backdrop-blur-sm z-40 opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<!-- Drawer -->
<div
  id="drawer"
  class="fixed top-0 right-0 h-full w-72 bg-white z-50 shadow-2xl translate-x-full transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] flex flex-col"
>
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
    <span class="text-sm font-semibold text-gray-400 tracking-widest uppercase">Menü</span>
    <button id="drawer-close" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-gray-100 transition-colors" aria-label="Bezárás">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 2L14 14M14 2L2 14" stroke="#374151" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <nav class="flex flex-col px-6 py-6 gap-1 flex-1">
    <a href={base + "#about"} class="drawer-link px-4 py-3 rounded-xl text-gray-700 font-medium hover:bg-indigo-50 hover:text-indigo-600 transition-colors">{t.nav.about}</a>
    <a href={base + "#services"} class="drawer-link px-4 py-3 rounded-xl text-gray-700 font-medium hover:bg-indigo-50 hover:text-indigo-600 transition-colors">{t.nav.services}</a>
    <a href={base + "#portfolio"} class="drawer-link px-4 py-3 rounded-xl text-gray-700 font-medium hover:bg-indigo-50 hover:text-indigo-600 transition-colors">{t.nav.portfolio}</a>
    <a href={base + "#contact"} class="drawer-link px-4 py-3 rounded-xl text-gray-700 font-medium hover:bg-indigo-50 hover:text-indigo-600 transition-colors">{t.nav.contact}</a>
    <a href={lang === "hu" ? "/gyik/" : "/en/faq/"} class="drawer-link px-4 py-3 rounded-xl text-gray-700 font-medium hover:bg-indigo-50 hover:text-indigo-600 transition-colors">{t.nav.faq}</a>
  </nav>

  <div class="px-6 py-6 border-t border-gray-100">
    <a
      href={otherLangHref}
      class="block text-center text-sm font-medium px-3 py-2 rounded-lg border border-gray-200 hover:border-indigo-400 hover:text-indigo-600 transition-all"
    >
      {otherLang.toUpperCase()}
    </a>
  </div>
</div>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const drawer = document.getElementById("drawer")!;
  const backdrop = document.getElementById("drawer-backdrop")!;
  const closeBtn = document.getElementById("drawer-close")!;
  const drawerLinks = document.querySelectorAll(".drawer-link");

  function openDrawer() {
    drawer.classList.remove("translate-x-full");
    backdrop.classList.remove("opacity-0", "pointer-events-none");
    toggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeDrawer() {
    drawer.classList.add("translate-x-full");
    backdrop.classList.add("opacity-0", "pointer-events-none");
    toggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  toggle.addEventListener("click", openDrawer);
  closeBtn.addEventListener("click", closeDrawer);
  backdrop.addEventListener("click", closeDrawer);
  drawerLinks.forEach(link => link.addEventListener("click", closeDrawer));

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeDrawer();
  });
</script>

<script>
  const header = document.querySelector("header");
  const isHome = ["/", "/en/"].includes(window.location.pathname);

  function updateNav() {
    const atTop = window.scrollY < 10;
    if (isHome && atTop) {
      header?.classList.add("nav-top");
      header?.classList.remove("nav-scrolled");
    } else {
      header?.classList.remove("nav-top");
      header?.classList.toggle("nav-scrolled", window.scrollY > 10);
    }
  }

  updateNav();
  window.addEventListener("scroll", updateNav, { passive: true });
</script>

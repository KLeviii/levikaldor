---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="services" class="py-20">
  <div class="max-w-5xl mx-auto px-4">
    <h2 data-animate class="text-3xl md:text-4xl font-bold text-(--text-primary) mb-12">{t.services.title}</h2>
    <div data-stagger class="grid md:grid-cols-2 gap-4">
      {t.services.items.map((item, i) => (
        <div class={[
          "p-6 rounded-lg transition-all duration-200 group",
          i === 0
            ? "md:col-span-2 bg-(--text-primary) text-(--text-inverse)"
            : "bg-(--bg-surface) border border-(--border-subtle) hover:border-(--border-medium) hover:shadow-(--shadow-md)"
        ].join(" ")}>
          <span class={["text-xs font-semibold uppercase tracking-widest mb-4 block", i === 0 ? "opacity-40" : "text-(--accent)"].join(" ")}>
            0{i + 1}
          </span>
          <h3 class={["text-lg font-semibold mb-2 transition-colors", i === 0 ? "group-hover:opacity-90" : "text-(--text-primary) group-hover:text-(--accent)"].join(" ")}>
            {item.title}
          </h3>
          <p class={["leading-relaxed text-sm", i === 0 ? "opacity-70" : "text-(--text-secondary)"].join(" ")}>
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

---
import '../../styles/global.css';
import { createSupabaseServerClient } from '../../lib/supabase';

interface Props {
  title: string;
  activePage: 'blog' | 'messages' | 'comments' | 'profile';
}

const { title, activePage } = Astro.props;

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);
const { data: { user } } = await supabase.auth.getUser();
const { count: pendingComments } = await supabase
  .from('blog_comments')
  .select('*', { count: 'exact', head: true })
  .eq('is_approved', false);
const userEmail = user?.email ?? '';
const displayName = (user?.user_metadata?.username as string | undefined) ?? userEmail;
const avatarLetter = (displayName.charAt(0) || 'A').toUpperCase();
---

<!doctype html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('kl-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} – Admin | levikaldor.hu</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet" />
</head>
<body class="bg-(--bg-base) text-(--text-primary) antialiased font-body">

  <!-- Mobile backdrop -->
  <div id="sidebar-backdrop"
    class="fixed inset-0 bg-black/40 z-30 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden">
  </div>

  <div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside id="admin-sidebar"
      class="fixed md:sticky top-0 left-0 h-screen w-64 md:w-56 z-40
             -translate-x-full md:translate-x-0
             bg-(--bg-surface) border-r border-(--border-subtle)
             flex flex-col shrink-0
             transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]">

      <div class="px-4 h-16 border-b border-(--border-subtle) flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 hover:opacity-75 transition-opacity">
          <img src="/favicon.svg" alt="KL" class="w-7 h-7" />
          <span class="text-sm font-semibold text-(--text-primary)">levikaldor.hu</span>
        </a>
        <!-- Mobile close -->
        <button id="sidebar-close" class="md:hidden p-1 text-(--text-tertiary) hover:text-(--text-primary) transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <nav class="flex-1 px-3 py-4 space-y-1">
        <a href="/admin/blog/"
          class={`flex items-center gap-2.5 px-3 py-2.5 rounded-md text-sm font-medium transition-colors
            ${activePage === 'blog'
              ? 'bg-(--accent-bg) text-(--accent) border border-(--accent-border)'
              : 'text-(--text-secondary) hover:bg-(--bg-elevated) hover:text-(--text-primary)'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
          Blog bejegyzések
        </a>
        <a href="/admin/messages/"
          class={`flex items-center gap-2.5 px-3 py-2.5 rounded-md text-sm font-medium transition-colors
            ${activePage === 'messages'
              ? 'bg-(--accent-bg) text-(--accent) border border-(--accent-border)'
              : 'text-(--text-secondary) hover:bg-(--bg-elevated) hover:text-(--text-primary)'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
            <path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
          </svg>
          Üzenetek
        </a>
        <a href="/admin/comments/"
          class={`flex items-center gap-2.5 px-3 py-2.5 rounded-md text-sm font-medium transition-colors
            ${activePage === 'comments'
              ? 'bg-(--accent-bg) text-(--accent) border border-(--accent-border)'
              : 'text-(--text-secondary) hover:bg-(--bg-elevated) hover:text-(--text-primary)'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          Hozzászólások
          {(pendingComments ?? 0) > 0 && (
            <span class="ml-auto px-1.5 py-0.5 rounded-full text-xs font-bold bg-(--accent) text-(--on-accent)">
              {pendingComments}
            </span>
          )}
        </a>
      </nav>

      <!-- Profile button -->
      <div class="px-3 py-4 border-t border-(--border-subtle) relative">
        <button id="profile-btn"
          class={`flex items-center gap-2.5 w-full px-3 py-2.5 rounded-md text-sm transition-colors
            ${activePage === 'profile'
              ? 'bg-(--accent-bg) text-(--accent) border border-(--accent-border)'
              : 'text-(--text-secondary) hover:bg-(--bg-elevated) hover:text-(--text-primary)'}`}>
          <span class="w-6 h-6 rounded-full bg-(--accent) text-(--on-accent) text-xs font-bold flex items-center justify-center shrink-0">
            {avatarLetter}
          </span>
          <span class="flex-1 text-left truncate">{displayName}</span>
          <svg id="profile-chevron" xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="18 15 12 9 6 15"/>
          </svg>
        </button>

        <!-- Dropdown -->
        <div id="profile-dropdown"
          class="hidden absolute bottom-full left-3 right-3 mb-1
                 bg-(--bg-surface) border border-(--border-subtle) rounded-lg shadow-(--shadow-lg)
                 overflow-hidden z-50">

          <div class="px-3 py-2.5 border-b border-(--border-subtle)">
            <p class="text-xs font-medium text-(--text-primary) truncate">{displayName}</p>
            <p class="text-xs text-(--text-tertiary) truncate mt-0.5">{userEmail}</p>
          </div>

          <div class="p-1">
            <a href="/admin/profile/"
              class="flex items-center gap-2.5 px-3 py-2 rounded-md text-sm text-(--text-secondary) hover:bg-(--bg-elevated) hover:text-(--text-primary) transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              Profil kezelés
            </a>

            <button id="admin-theme-toggle"
              class="flex items-center gap-2.5 w-full px-3 py-2 rounded-md text-sm text-(--text-secondary) hover:bg-(--bg-elevated) hover:text-(--text-primary) transition-colors">
              <svg class="w-4 h-4 dark:hidden shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
              <svg class="w-4 h-4 hidden dark:block shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
              Téma váltás
            </button>
          </div>

          <div class="p-1 border-t border-(--border-subtle)">
            <form method="POST" action="/api/auth/logout">
              <button type="submit"
                class="flex items-center gap-2.5 w-full px-3 py-2 rounded-md text-sm text-(--text-secondary) hover:bg-red-50 dark:hover:bg-red-950/30 hover:text-red-600 dark:hover:text-red-400 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                  <polyline points="16 17 21 12 16 7"/>
                  <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Kijelentkezés
              </button>
            </form>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main -->
    <div class="flex-1 flex flex-col min-w-0">
      <header class="sticky top-0 z-20 px-4 md:px-6 h-16 border-b border-(--border-subtle) bg-(--bg-surface)/80 backdrop-blur flex items-center gap-3">
        <!-- Mobile hamburger -->
        <button id="sidebar-open" class="md:hidden p-1.5 -ml-1 text-(--text-secondary) hover:text-(--text-primary) hover:bg-(--bg-elevated) rounded-md transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <h1 class="text-base md:text-lg font-semibold text-(--text-primary)">{title}</h1>
      </header>
      <main class="flex-1 p-4 md:p-6 overflow-auto">
        <slot />
      </main>
    </div>

  </div>

  <script>
    // Theme toggle
    document.getElementById('admin-theme-toggle')?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('kl-theme', isDark ? 'dark' : 'light');
    });

    // Profile dropdown
    const profileBtn = document.getElementById('profile-btn')!;
    const profileDropdown = document.getElementById('profile-dropdown')!;
    const profileChevron = document.getElementById('profile-chevron')!;

    function toggleProfileDropdown() {
      const isOpen = !profileDropdown.classList.contains('hidden');
      if (isOpen) {
        profileDropdown.classList.add('hidden');
        profileChevron.style.transform = '';
      } else {
        profileDropdown.classList.remove('hidden');
        profileChevron.style.transform = 'rotate(180deg)';
      }
    }

    profileBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleProfileDropdown();
    });

    document.addEventListener('click', (e) => {
      if (!profileDropdown.contains(e.target as Node) && !profileBtn.contains(e.target as Node)) {
        profileDropdown.classList.add('hidden');
        profileChevron.style.transform = '';
      }
    });

    const sidebar   = document.getElementById('admin-sidebar')!;
    const backdrop  = document.getElementById('sidebar-backdrop')!;
    const openBtn   = document.getElementById('sidebar-open')!;
    const closeBtn  = document.getElementById('sidebar-close')!;

    function openSidebar() {
      sidebar.classList.remove('-translate-x-full');
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
      sidebar.classList.add('-translate-x-full');
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    backdrop.addEventListener('click', closeSidebar);
  </script>
</body>
</html>

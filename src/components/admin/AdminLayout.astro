---
import '../../styles/global.css';

interface Props {
  title: string;
  activePage: 'blog' | 'messages';
}

const { title, activePage } = Astro.props;
---

<!doctype html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('kl-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} – Admin | levikaldor.hu</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet" />
</head>
<body class="bg-(--bg-base) text-(--text-primary) antialiased font-body">
  <div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-56 shrink-0 bg-(--bg-surface) border-r border-(--border-subtle) flex flex-col">
      <div class="px-4 py-5 border-b border-(--border-subtle)">
        <a href="/" class="flex items-center gap-2.5 hover:opacity-75 transition-opacity">
          <img src="/favicon.svg" alt="KL" class="w-7 h-7" />
          <span class="text-sm font-semibold text-(--text-primary)">levikaldor.hu</span>
        </a>
      </div>

      <nav class="flex-1 px-3 py-4 space-y-1">
        <a href="/admin/blog/"
          class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium transition-colors
            ${activePage === 'blog'
              ? 'bg-(--accent-bg) text-(--accent) border border-(--accent-border)'
              : 'text-(--text-secondary) hover:bg-(--bg-elevated) hover:text-(--text-primary)'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
          Blog bejegyzések
        </a>
        <a href="/admin/messages/"
          class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium transition-colors
            ${activePage === 'messages'
              ? 'bg-(--accent-bg) text-(--accent) border border-(--accent-border)'
              : 'text-(--text-secondary) hover:bg-(--bg-elevated) hover:text-(--text-primary)'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
            <path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
          </svg>
          Üzenetek
        </a>
      </nav>

      <div class="px-3 py-4 border-t border-(--border-subtle) space-y-1">
        <button id="admin-theme-toggle"
          class="flex items-center gap-2.5 w-full px-3 py-2 rounded-md text-sm text-(--text-secondary) hover:bg-(--bg-elevated) hover:text-(--text-primary) transition-colors">
          <svg class="w-4 h-4 dark:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg class="w-4 h-4 hidden dark:block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          Téma
        </button>
        <form method="POST" action="/api/auth/logout">
          <button type="submit"
            class="flex items-center gap-2.5 w-full px-3 py-2 rounded-md text-sm text-(--text-secondary) hover:bg-red-50 dark:hover:bg-red-950/30 hover:text-red-600 dark:hover:text-red-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/>
              <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Kijelentkezés
          </button>
        </form>
      </div>
    </aside>

    <!-- Main -->
    <div class="flex-1 flex flex-col min-w-0">
      <header class="px-6 py-4 border-b border-(--border-subtle) bg-(--bg-surface)/60 backdrop-blur">
        <h1 class="text-lg font-semibold text-(--text-primary)">{title}</h1>
      </header>
      <main class="flex-1 p-6 overflow-auto">
        <slot />
      </main>
    </div>

  </div>

  <script>
    document.getElementById('admin-theme-toggle')?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('kl-theme', isDark ? 'dark' : 'light');
    });
  </script>
</body>
</html>

---
import type { BlogPost } from '../../lib/supabase';

interface Props {
  post?: BlogPost;
  error?: string;
}

const { post, error } = Astro.props;
const isEdit = !!post;
---

<form method="POST" enctype="multipart/form-data" class="space-y-6 max-w-4xl" id="post-form">
  {error && (
    <div class="px-4 py-3 bg-red-50 dark:bg-red-950/30 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 text-sm rounded-md">
      {error}
    </div>
  )}

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="md:col-span-2">
      <label class="block text-sm font-medium text-(--text-secondary) mb-1.5">
        Slug <span class="text-(--text-tertiary) font-normal">(URL: /blog/slug/)</span>
      </label>
      <input type="text" name="slug" value={post?.slug ?? ''} required
        placeholder="pl. astro-supabase-integralas"
        class="w-full px-4 py-2.5 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md focus:outline-none focus:border-(--accent) transition font-mono text-sm" />
    </div>
    <div>
      <label class="block text-sm font-medium text-(--text-secondary) mb-1.5">Státusz</label>
      <input type="hidden" name="status" id="status-input" value={post?.status ?? 'draft'} />
      <div class="relative" id="status-dropdown">
        <button type="button" id="status-trigger"
          class="w-full flex items-center justify-between gap-2 px-4 py-2.5 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md hover:border-(--border-medium) transition text-sm text-left">
          <span id="status-label" class="flex items-center gap-2">
            {(!post || post.status === 'draft') ? (
              <><span class="inline-block w-2 h-2 rounded-full bg-(--text-tertiary)"></span>Vázlat</>
            ) : (
              <><span class="inline-block w-2 h-2 rounded-full bg-green-500"></span>Publikált</>
            )}
          </span>
          <svg id="status-chevron" class="w-4 h-4 text-(--text-tertiary) transition-transform duration-200 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
        <div id="status-menu"
          class="absolute z-20 top-full left-0 right-0 mt-1 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) rounded-md shadow-(--shadow-lg) overflow-hidden hidden">
          <button type="button" data-value="draft"
            class="status-option w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-(--text-primary) hover:bg-(--bg-surface) dark:hover:bg-(--bg-base) transition-colors text-left">
            <span class="inline-block w-2 h-2 rounded-full bg-(--text-tertiary) shrink-0"></span>
            Vázlat
          </button>
          <button type="button" data-value="published"
            class="status-option w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-(--text-primary) hover:bg-(--bg-surface) dark:hover:bg-(--bg-base) transition-colors text-left">
            <span class="inline-block w-2 h-2 rounded-full bg-green-500 shrink-0"></span>
            Publikált
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Cover image upload -->
  <div>
    <label class="block text-sm font-medium text-(--text-secondary) mb-1.5">Borítókép</label>
    <input type="hidden" name="cover_url" id="cover_url_input" value={post?.cover_url ?? ''} />
    <div class="flex items-center gap-4">
      {post?.cover_url && (
        <img id="cover_preview" src={post.cover_url} alt="Borítókép" class="h-16 w-auto rounded-md border border-(--border-subtle) object-cover" />
      )}
      {!post?.cover_url && (
        <img id="cover_preview" src="" alt="Borítókép" class="h-16 w-auto rounded-md border border-(--border-subtle) object-cover hidden" />
      )}
      <button type="button" id="open-upload-modal"
        class="inline-flex items-center gap-2 px-4 py-2.5 border border-(--border-subtle) hover:border-(--accent) text-(--text-secondary) hover:text-(--accent) rounded-md text-sm font-medium transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="17 8 12 3 7 8"/>
          <line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
        Kép feltöltése
      </button>
    </div>
  </div>

  <!-- Upload modal -->
  <div id="upload-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 hidden">
    <div id="upload-backdrop" class="fixed inset-0 bg-black/50 backdrop-blur-sm" style="opacity:0;transition:opacity 0.2s ease;"></div>
    <div class="relative bg-(--bg-surface) border border-(--border-subtle) rounded-xl shadow-2xl w-full max-w-md p-6"
      style="opacity:0;transform:scale(0.95) translateY(8px);transition:opacity 0.22s cubic-bezier(0.16,1,0.3,1),transform 0.22s cubic-bezier(0.16,1,0.3,1);">
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-semibold text-(--text-primary)">Borítókép feltöltése</h3>
        <button type="button" id="close-upload-modal" class="p-1 text-(--text-tertiary) hover:text-(--text-primary) transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <!-- Drop zone -->
      <div id="drop-zone"
        class="border-2 border-dashed border-(--border-subtle) rounded-lg p-10 flex flex-col items-center justify-center gap-3 text-center cursor-pointer transition-colors hover:border-(--accent) hover:bg-(--accent-bg)">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-(--text-tertiary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="17 8 12 3 7 8"/>
          <line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
        <div>
          <p class="text-sm font-medium text-(--text-primary)">Húzd ide a képet</p>
          <p class="text-xs text-(--text-tertiary) mt-1">vagy</p>
        </div>
        <button type="button" id="pick-file-btn"
          class="px-4 py-2 bg-(--accent) hover:bg-(--accent-bright) text-(--on-accent) text-sm font-medium rounded-md transition-colors">
          Fájl megnyitása
        </button>
        <p class="text-xs text-(--text-tertiary)">JPG, PNG, WebP – max. 5 MB</p>
        <input type="file" id="cover_file" accept="image/*" class="hidden" />
      </div>

      <!-- Progress -->
      <div id="upload_progress" class="hidden mt-4">
        <div class="h-1.5 bg-(--bg-elevated) rounded-full overflow-hidden">
          <div id="upload_bar" class="h-full bg-(--accent) transition-all duration-300" style="width: 0%"></div>
        </div>
        <p id="upload_status" class="text-xs text-(--text-tertiary) mt-1.5">Feltöltés...</p>
      </div>
    </div>
  </div>

  <!-- Tags -->
  <div>
    <label class="block text-sm font-medium text-(--text-secondary) mb-1.5">Tagek <span class="text-(--text-tertiary) font-normal">(vesszővel elválasztva)</span></label>
    <input type="text" name="tags" value={post?.tags?.join(', ') ?? ''}
      placeholder="astro, supabase, webfejlesztés"
      class="w-full px-4 py-2.5 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md focus:outline-none focus:border-(--accent) transition" />
  </div>

  <!-- Reading time -->
  <div class="w-40">
    <label class="block text-sm font-medium text-(--text-secondary) mb-1.5">Olvasási idő (perc)</label>
    <div class="flex items-center bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) rounded-md overflow-hidden focus-within:border-(--accent) transition">
      <input type="number" name="reading_time_min" id="reading-time-input"
        value={post?.reading_time_min ?? ''} min="1" max="60" placeholder="5"
        class="w-full px-4 py-2.5 bg-transparent text-(--text-primary) focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none text-sm" />
      <div class="flex flex-col border-l border-(--border-subtle) shrink-0">
        <button type="button" id="rt-up"
          class="px-2 py-1.5 text-(--text-secondary) hover:text-(--accent) hover:bg-(--bg-surface) dark:hover:bg-(--bg-base) transition-colors leading-none">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
        </button>
        <div class="border-t border-(--border-subtle)"></div>
        <button type="button" id="rt-down"
          class="px-2 py-1.5 text-(--text-secondary) hover:text-(--accent) hover:bg-(--bg-surface) dark:hover:bg-(--bg-base) transition-colors leading-none">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Language tabs -->
  <div class="border border-(--border-subtle) rounded-lg overflow-hidden">
    <div class="flex border-b border-(--border-subtle) bg-(--bg-elevated)">
      <button type="button" id="tab-hu"
        class="px-5 py-3 text-sm font-medium text-(--accent) border-b-2 border-(--accent)">
        Magyar (HU)
      </button>
      <button type="button" id="tab-en"
        class="px-5 py-3 text-sm font-medium text-(--text-secondary) hover:text-(--text-primary) border-b-2 border-transparent transition-colors">
        English (EN)
      </button>
    </div>

    <div id="panel-hu" class="p-5 space-y-4">
      <div>
        <label class="block text-sm font-medium text-(--text-secondary) mb-1.5">Cím (HU) <span class="text-(--accent)">*</span></label>
        <input type="text" name="title_hu" value={post?.title_hu ?? ''} required
          class="w-full px-4 py-2.5 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md focus:outline-none focus:border-(--accent) transition" />
      </div>
      <div>
        <label class="block text-sm font-medium text-(--text-secondary) mb-1.5">Kivonat (HU)</label>
        <textarea name="excerpt_hu" rows={2}
          class="w-full px-4 py-2.5 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md focus:outline-none focus:border-(--accent) transition resize-none">{post?.excerpt_hu ?? ''}</textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-(--text-secondary) mb-1.5">Tartalom – Markdown (HU) <span class="text-(--accent)">*</span></label>
        <div class="relative">
          <textarea name="content_hu" rows={18} required
            class="resizable-ta w-full px-4 py-2.5 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md focus:outline-none focus:border-(--accent) transition resize-none font-mono text-sm">{post?.content_hu ?? ''}</textarea>
          <div class="resize-handle" aria-hidden="true">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="9" y1="1" x2="1" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="9" y1="5" x2="5" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <div id="panel-en" class="p-5 space-y-4 hidden">
      <p class="text-xs text-(--text-tertiary) bg-(--accent-bg) border border-(--accent-border) rounded-md px-3 py-2">
        Opcionális. Ha nincs kitöltve, az EN blog listán ez a poszt nem jelenik meg.
      </p>
      <div>
        <label class="block text-sm font-medium text-(--text-secondary) mb-1.5">Title (EN)</label>
        <input type="text" name="title_en" value={post?.title_en ?? ''}
          class="w-full px-4 py-2.5 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md focus:outline-none focus:border-(--accent) transition" />
      </div>
      <div>
        <label class="block text-sm font-medium text-(--text-secondary) mb-1.5">Excerpt (EN)</label>
        <textarea name="excerpt_en" rows={2}
          class="w-full px-4 py-2.5 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md focus:outline-none focus:border-(--accent) transition resize-none">{post?.excerpt_en ?? ''}</textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-(--text-secondary) mb-1.5">Content – Markdown (EN)</label>
        <div class="relative">
          <textarea name="content_en" rows={18}
            class="resizable-ta w-full px-4 py-2.5 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md focus:outline-none focus:border-(--accent) transition resize-none font-mono text-sm">{post?.content_en ?? ''}</textarea>
          <div class="resize-handle" aria-hidden="true">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="9" y1="1" x2="1" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="9" y1="5" x2="5" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <button type="submit"
      class="px-6 py-2.5 bg-(--accent) hover:bg-(--accent-bright) text-(--on-accent) font-semibold rounded-md transition-colors">
      {isEdit ? 'Mentés' : 'Létrehozás'}
    </button>
    <a href="/admin/blog/"
      class="px-6 py-2.5 border border-(--border-subtle) hover:border-(--border-medium) text-(--text-secondary) font-medium rounded-md transition-colors">
      Mégse
    </a>
    {isEdit && (
      <button type="submit" name="_action" value="delete" formnovalidate
        class="ml-auto px-4 py-2.5 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950/30 border border-red-200 dark:border-red-800 rounded-md text-sm font-medium transition-colors"
        onclick="return confirm('Biztosan törlöd ezt a bejegyzést?')">
        Törlés
      </button>
    )}
  </div>
</form>

<script>
  // Tab switching
  const tabHu = document.getElementById('tab-hu')!;
  const tabEn = document.getElementById('tab-en')!;
  const panelHu = document.getElementById('panel-hu')!;
  const panelEn = document.getElementById('panel-en')!;

  function activateTab(tab: 'hu' | 'en') {
    if (tab === 'hu') {
      tabHu.classList.add('text-(--accent)', 'border-(--accent)');
      tabHu.classList.remove('text-(--text-secondary)', 'border-transparent');
      tabEn.classList.remove('text-(--accent)', 'border-(--accent)');
      tabEn.classList.add('text-(--text-secondary)', 'border-transparent');
      panelHu.classList.remove('hidden');
      panelEn.classList.add('hidden');
    } else {
      tabEn.classList.add('text-(--accent)', 'border-(--accent)');
      tabEn.classList.remove('text-(--text-secondary)', 'border-transparent');
      tabHu.classList.remove('text-(--accent)', 'border-(--accent)');
      tabHu.classList.add('text-(--text-secondary)', 'border-transparent');
      panelEn.classList.remove('hidden');
      panelHu.classList.add('hidden');
    }
  }

  tabHu.addEventListener('click', () => activateTab('hu'));
  tabEn.addEventListener('click', () => activateTab('en'));

  // Custom number stepper
  const rtInput = document.getElementById('reading-time-input') as HTMLInputElement;
  document.getElementById('rt-up')?.addEventListener('click', () => {
    const val = parseInt(rtInput.value) || 0;
    if (val < 60) rtInput.value = String(val + 1);
  });
  document.getElementById('rt-down')?.addEventListener('click', () => {
    const val = parseInt(rtInput.value) || 2;
    if (val > 1) rtInput.value = String(val - 1);
  });

  // Custom status dropdown
  const statusTrigger = document.getElementById('status-trigger')!;
  const statusMenu = document.getElementById('status-menu')!;
  const statusInput = document.getElementById('status-input') as HTMLInputElement;
  const statusLabel = document.getElementById('status-label')!;
  const statusChevron = document.getElementById('status-chevron')!;

  const labels: Record<string, string> = {
    draft: '<span class="inline-block w-2 h-2 rounded-full bg-(--text-tertiary)"></span>Vázlat',
    published: '<span class="inline-block w-2 h-2 rounded-full bg-green-500"></span>Publikált',
  };

  statusTrigger.addEventListener('click', () => {
    const isOpen = !statusMenu.classList.contains('hidden');
    statusMenu.classList.toggle('hidden', isOpen);
    statusChevron.classList.toggle('rotate-180', !isOpen);
  });

  document.querySelectorAll('.status-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const value = (btn as HTMLElement).dataset.value!;
      statusInput.value = value;
      statusLabel.innerHTML = labels[value];
      statusMenu.classList.add('hidden');
      statusChevron.classList.remove('rotate-180');
    });
  });

  document.addEventListener('click', (e) => {
    if (!document.getElementById('status-dropdown')?.contains(e.target as Node)) {
      statusMenu.classList.add('hidden');
      statusChevron.classList.remove('rotate-180');
    }
  });

  // Custom textarea resize handles
  document.querySelectorAll<HTMLElement>('.resize-handle').forEach(handle => {
    const ta = handle.previousElementSibling as HTMLTextAreaElement;
    let startY = 0;
    let startH = 0;

    handle.addEventListener('mousedown', (e: MouseEvent) => {
      startY = e.clientY;
      startH = ta.offsetHeight;
      document.body.style.cursor = 'ns-resize';
      document.body.style.userSelect = 'none';

      function onMove(e: MouseEvent) {
        const newH = Math.max(80, startH + e.clientY - startY);
        ta.style.height = newH + 'px';
      }
      function onUp() {
        document.body.style.cursor = '';
        document.body.style.userSelect = '';
        window.removeEventListener('mousemove', onMove);
        window.removeEventListener('mouseup', onUp);
      }
      window.addEventListener('mousemove', onMove);
      window.addEventListener('mouseup', onUp);
    });
  });

  // Upload modal
  const modal        = document.getElementById('upload-modal')!;
  const openBtn      = document.getElementById('open-upload-modal')!;
  const closeBtn     = document.getElementById('close-upload-modal')!;
  const backdrop     = document.getElementById('upload-backdrop')!;
  const dropZone     = document.getElementById('drop-zone')!;
  const pickFileBtn  = document.getElementById('pick-file-btn')!;
  const fileInput    = document.getElementById('cover_file') as HTMLInputElement;
  const coverUrlInput = document.getElementById('cover_url_input') as HTMLInputElement;
  const uploadProgress = document.getElementById('upload_progress')!;
  const uploadBar    = document.getElementById('upload_bar') as HTMLElement;
  const uploadStatus = document.getElementById('upload_status')!;
  const coverPreview = document.getElementById('cover_preview') as HTMLImageElement;

  const modalPanel = modal.querySelector('.relative') as HTMLElement;

  function openModal() {
    modal.classList.remove('hidden');
    requestAnimationFrame(() => {
      backdrop.style.opacity = '1';
      modalPanel.style.opacity = '1';
      modalPanel.style.transform = 'scale(1) translateY(0)';
    });
  }

  function closeModal() {
    backdrop.style.opacity = '0';
    modalPanel.style.opacity = '0';
    modalPanel.style.transform = 'scale(0.95) translateY(8px)';
    setTimeout(() => modal.classList.add('hidden'), 220);
  }

  openBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  pickFileBtn.addEventListener('click', () => fileInput.click());

  // Drag & drop styling
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-(--accent)', 'bg-(--accent-bg)');
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-(--accent)', 'bg-(--accent-bg)');
  });
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-(--accent)', 'bg-(--accent-bg)');
    const file = e.dataTransfer?.files?.[0];
    if (file && file.type.startsWith('image/')) uploadFile(file);
  });

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) uploadFile(file);
  });

  async function uploadFile(file: File) {
    uploadProgress.classList.remove('hidden');
    uploadBar.style.width = '20%';
    uploadBar.classList.remove('bg-red-500');
    uploadBar.classList.add('bg-(--accent)');
    uploadStatus.textContent = 'Feltöltés...';

    try {
      const fd = new FormData();
      fd.append('file', file);
      uploadBar.style.width = '50%';

      const res = await fetch('/api/upload-cover', { method: 'POST', body: fd });
      const json = await res.json();
      if (!res.ok) throw new Error(json.error ?? 'Ismeretlen hiba');

      coverUrlInput.value = json.url;
      coverPreview.src = json.url;
      coverPreview.classList.remove('hidden');
      uploadBar.style.width = '100%';
      uploadStatus.textContent = 'Sikeresen feltöltve!';

      setTimeout(() => {
        closeModal();
        uploadProgress.classList.add('hidden');
        uploadBar.style.width = '0%';
      }, 1200);
    } catch (err: any) {
      uploadBar.style.width = '100%';
      uploadBar.classList.add('bg-red-500');
      uploadBar.classList.remove('bg-(--accent)');
      uploadStatus.textContent = `Hiba: ${err.message ?? 'próbáld újra'}`;
      console.error(err);
    }
  }
</script>

<style>
  .resize-handle {
    position: absolute;
    bottom: 6px;
    right: 3px;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: ns-resize;
    color: var(--text-tertiary);
    border-radius: 3px;
    transition: color 0.15s;
  }
  .resize-handle:hover {
    color: var(--accent);
  }
</style>

---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { hu as t } from "../i18n/hu";

const SITE = "https://levikaldor.hu";
---

<Layout
  lang="hu"
  title={t.summary.metaTitle}
  description={t.summary.metaDescription}
  canonical={`${SITE}/osszegzes/`}
  noindex={true}
>
  <Navbar lang="hu" />

  <main class="pt-32 pb-20 min-h-[calc(100vh-var(--footer-h,80px))]">
    <div class="max-w-3xl mx-auto px-4">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-10" data-animate style="transition-delay: 0ms">
        <ol class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500">
          <li>
            <a href="/" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">Főoldal</a>
          </li>
          <li aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </li>
          <li>
            <a href="/arak/" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">{t.summary.breadcrumbPricing}</a>
          </li>
          <li aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </li>
          <li>
            <span class="text-gray-600 dark:text-gray-300 font-medium" aria-current="page">{t.summary.breadcrumbSummary}</span>
          </li>
        </ol>
      </nav>

      <h1
        class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-10"
        data-animate
        style="transition-delay: 60ms"
      >
        {t.summary.title}
      </h1>

      <noscript>
        <meta http-equiv="refresh" content="0;url=/arak/" />
        <p class="text-gray-600 dark:text-gray-300">JavaScript szükséges. <a href="/arak/" class="text-indigo-600 underline">Vissza az árkalkulátorhoz.</a></p>
      </noscript>

      <!-- Empty state -->
      <div id="summary-empty" class="hidden text-center py-20" data-animate style="transition-delay: 120ms">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gray-100 dark:bg-gray-800 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 dark:text-gray-500"><path d="M9 14l-4-4 4-4"/><path d="M5 10h11a4 4 0 0 1 0 8h-1"/></svg>
        </div>
        <p class="text-gray-600 dark:text-gray-300 mb-6 text-lg">{t.summary.empty}</p>
        <a href="/arak/" class="inline-block px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-semibold transition-colors">
          {t.summary.backLink}
        </a>
      </div>

      <!-- Summary content -->
      <div id="summary-content" class="hidden">

        <!-- Total card -->
        <!-- Total card -->
<div
  class="mb-6 p-8 bg-indigo-50 dark:bg-indigo-900/20 rounded-2xl flex items-center justify-between gap-6"
  data-animate
  style="transition-delay: 120ms"
>
  <div>
    <p class="text-lg font-bold text-gray-900 dark:text-white">{t.summary.totalLabel}</p>
    <p class="text-sm text-gray-400 dark:text-gray-500 mt-0.5">{t.summary.disclaimer}</p>
  </div>
  <p id="summary-total" class="text-3xl font-bold text-indigo-600 dark:text-indigo-400 shrink-0"></p>
</div>

        <!-- Project type -->
        <div
          id="project-type-row"
          class="hidden mb-3 p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900"
          data-animate
          style="transition-delay: 180ms"
        >
          <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3">{t.summary.projectTypeLabel}</p>
          <div class="flex items-center justify-between gap-4">
            <span id="project-type-label" class="font-medium text-gray-800 dark:text-gray-100 text-sm"></span>
            <span id="project-type-price" class="font-semibold text-indigo-600 dark:text-indigo-400 text-sm shrink-0"></span>
          </div>
        </div>

        <!-- Modules list -->
        <div
          id="modules-list"
          class="hidden mb-8"
          data-animate
          style="transition-delay: 240ms"
        >
          <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3 mt-6">{t.summary.modulesLabel}</p>
          <div id="modules-rows" class="space-y-2"></div>
        </div>

        <!-- CTA -->
        <div
          class="flex flex-col sm:flex-row gap-3 mt-8"
          data-animate
          style="transition-delay: 300ms"
        >
          <a
            href="/#contact"
            class="flex-1 text-center px-6 py-3 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white rounded-xl font-semibold transition-colors shadow-md"
          >
            {t.summary.ctaLabel}
          </a>
          <a
            href="/arak/"
            class="flex-1 text-center px-6 py-3 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-indigo-400 dark:hover:border-indigo-500 rounded-xl font-semibold transition-colors"
          >
            {t.summary.backLink}
          </a>
        </div>

      </div>

    </div>
  </main>

  <Footer lang="hu" />
</Layout>

<script>
  // ── Adatok ──────────────────────────────────────────────────────────────────
  const PROJECT_TYPES: Record<string, { label: string; price: number; isFlat: boolean }> = {
    landing:      { label: "Landing page",           price: 0,      isFlat: false },
    portfolio:    { label: "Portfólió oldal",         price: 50000,  isFlat: false },
    webshop:      { label: "Webshop",                price: 150000, isFlat: false },
    optimization: { label: "Weboldal optimalizálás", price: 80000,  isFlat: true  },
  };

  const MODULES: Record<string, { label: string; price: number; cat: string }> = {
    "contact-form":     { label: "Kapcsolatfelvételi űrlap",                price: 25000, cat: "Funkcionális modulok" },
    "blog":             { label: "Blog rendszer",                            price: 60000, cat: "Funkcionális modulok" },
    "gallery":          { label: "Képgaléria",                               price: 30000, cat: "Funkcionális modulok" },
    "webshop-cart":     { label: "Kosár és checkout",                        price: 80000, cat: "Funkcionális modulok" },
    "search":           { label: "Keresés",                                  price: 35000, cat: "Funkcionális modulok" },
    "auth":             { label: "Felhasználói regisztráció / bejelentkezés",price: 70000, cat: "Funkcionális modulok" },
    "booking":          { label: "Foglalási rendszer",                       price: 90000, cat: "Funkcionális modulok" },
    "newsletter":       { label: "Hírlevél feliratkozás",                    price: 20000, cat: "Funkcionális modulok" },
    "animations":       { label: "Egyedi animációk",                         price: 30000, cat: "Design modulok" },
    "dark-mode":        { label: "Sötét mód",                                price: 20000, cat: "Design modulok" },
    "typography":       { label: "Egyedi tipográfia",                        price: 15000, cat: "Design modulok" },
    "illustrations":    { label: "Egyedi illusztrációk",                     price: 50000, cat: "Design modulok" },
    "parallax":         { label: "Parallax effektek",                        price: 25000, cat: "Design modulok" },
    "seo":              { label: "SEO optimalizálás",                        price: 40000, cat: "Nem-funkcionális modulok" },
    "performance":      { label: "Teljesítmény optimalizálás",               price: 35000, cat: "Nem-funkcionális modulok" },
    "accessibility":    { label: "Akadálymentességi audit",                  price: 30000, cat: "Nem-funkcionális modulok" },
    "i18n":             { label: "Többnyelvűsítés (i18n)",                   price: 50000, cat: "Nem-funkcionális modulok" },
    "ssl":              { label: "SSL beállítás",                            price: 15000, cat: "Biztonságkritikus modulok" },
    "gdpr":             { label: "GDPR megfelelőség",                        price: 35000, cat: "Biztonságkritikus modulok" },
    "spam-protection":  { label: "Spam védelem",                             price: 20000, cat: "Biztonságkritikus modulok" },
    "security-headers": { label: "Biztonsági fejlécek",                      price: 15000, cat: "Biztonságkritikus modulok" },
    "backup":           { label: "Backup rendszer",                          price: 25000, cat: "Biztonságkritikus modulok" },
  };

  const BASE = 150000;

  function formatHUF(n: number): string {
    return n.toLocaleString("hu-HU") + " Ft";
  }

  // ── URL paraméterek feldolgozása ────────────────────────────────────────────
  const params = new URLSearchParams(window.location.search);
  const typeId = params.get("type");
  const moduleIds = params.getAll("m");

  const projectType = typeId ? PROJECT_TYPES[typeId] : null;
  const validModules = moduleIds.filter((id) => MODULES[id] && !(projectType?.isFlat));

  let total: number;
  if (projectType?.isFlat) {
    total = projectType.price;
  } else {
    const projectAdd = projectType?.price ?? 0;
    const modulesSum = validModules.reduce((sum, id) => sum + MODULES[id].price, 0);
    total = BASE + projectAdd + modulesSum;
  }

  const hasContent = projectType || validModules.length > 0;

  // ── Megjelenítés ────────────────────────────────────────────────────────────
  if (!hasContent) {
    document.getElementById("summary-empty")?.classList.remove("hidden");
  } else {
    document.getElementById("summary-content")?.classList.remove("hidden");

    // Total
    const totalEl = document.getElementById("summary-total");
    if (totalEl) totalEl.textContent = formatHUF(total);

    // Project type
    if (projectType) {
      const row = document.getElementById("project-type-row");
      const labelEl = document.getElementById("project-type-label");
      const priceEl = document.getElementById("project-type-price");
      row?.classList.remove("hidden");
      if (labelEl) labelEl.textContent = projectType.label;
      if (priceEl) {
        priceEl.textContent = projectType.isFlat
          ? formatHUF(projectType.price) + " (fix ár)"
          : projectType.price === 0
            ? "Alap díj"
            : `+${formatHUF(projectType.price)}`;
      }
    }

    // Modules list
    if (validModules.length > 0) {
      document.getElementById("modules-list")?.classList.remove("hidden");
      const container = document.getElementById("modules-rows");
      if (container) {
        const grouped = new Map<string, string[]>();
        validModules.forEach((id) => {
          const cat = MODULES[id].cat;
          if (!grouped.has(cat)) grouped.set(cat, []);
          grouped.get(cat)!.push(id);
        });

        grouped.forEach((ids, catLabel) => {
          const catHeader = document.createElement("p");
          catHeader.className = "text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mt-5 mb-2 first:mt-0";
          catHeader.textContent = catLabel;
          container.appendChild(catHeader);

          ids.forEach((id) => {
            const mod = MODULES[id];
            const row = document.createElement("div");
            row.className = "flex items-center justify-between gap-4 px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900";
            row.innerHTML = `
              <span class="text-sm font-medium text-gray-800 dark:text-gray-100">${mod.label}</span>
              <span class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 shrink-0">+${formatHUF(mod.price)}</span>
            `;
            container.appendChild(row);
          });
        });
      }
    }
  }

  // ── Felúszós animáció ───────────────────────────────────────────────────────
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
</script>
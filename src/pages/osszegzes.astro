---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { hu as t } from "../i18n/hu";

const SITE = "https://levikaldor.hu";
---

<Layout
  lang="hu"
  title={t.summary.metaTitle}
  description={t.summary.metaDescription}
  canonical={`${SITE}/osszegzes/`}
  noindex={true}
>
  <Navbar lang="hu" />

  <main class="pt-32 pb-20 min-h-[calc(100vh-var(--footer-h,80px))]">
    <div class="max-w-3xl mx-auto px-4">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-10" data-animate style="transition-delay: 0ms">
        <ol class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500">
          <li>
            <a href="/" class="hover:text-(--accent) transition-colors">Főoldal</a>
          </li>
          <li aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </li>
          <li>
            <a href="/arak/" class="hover:text-(--accent) transition-colors">{t.summary.breadcrumbPricing}</a>
          </li>
          <li aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </li>
          <li>
            <span class="text-gray-600 dark:text-gray-300 font-medium" aria-current="page">{t.summary.breadcrumbSummary}</span>
          </li>
        </ol>
      </nav>

      <h1
        class="text-4xl md:text-5xl font-bold text-(--text-primary) mb-10"
        data-animate
        style="transition-delay: 60ms"
      >
        {t.summary.title}
      </h1>

      <noscript>
        <meta http-equiv="refresh" content="0;url=/arak/" />
        <p class="text-(--text-secondary)">JavaScript szükséges. <a href="/arak/" class="text-(--accent) underline">Vissza az árkalkulátorhoz.</a></p>
      </noscript>

      <!-- Empty state -->
      <div id="summary-empty" class="hidden text-center py-20" data-animate style="transition-delay: 120ms">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-lg bg-gray-100 dark:bg-gray-800 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 dark:text-gray-500"><path d="M9 14l-4-4 4-4"/><path d="M5 10h11a4 4 0 0 1 0 8h-1"/></svg>
        </div>
        <p class="text-(--text-secondary) mb-6 text-lg">{t.summary.empty}</p>
        <a href="/arak/" class="inline-block px-6 py-3 bg-(--accent) hover:bg-(--accent-bright) text-(--on-accent) rounded-md font-semibold transition-colors">
          {t.summary.backLink}
        </a>
      </div>

      <!-- Summary content -->
      <div id="summary-content" class="hidden">

        <!-- Total card -->
        <!-- Total card -->
<div
  class="mb-6 p-8 bg-(--accent-bg) border border-(--accent-border) rounded-lg flex items-center justify-between gap-6"
  data-animate
  style="transition-delay: 120ms"
>
  <div>
    <p class="text-lg font-bold text-(--text-primary)">{t.summary.totalLabel}</p>
    <p class="text-sm text-(--text-tertiary) mt-0.5">{t.summary.disclaimer}</p>
  </div>
  <p id="summary-total" class="text-3xl font-bold text-(--accent) shrink-0"></p>
</div>

        <!-- Project type -->
        <div
          id="project-type-row"
          class="hidden mb-3 p-4 rounded-md border border-(--border-subtle) bg-white dark:bg-(--bg-surface)"
          data-animate
          style="transition-delay: 180ms"
        >
          <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3">{t.summary.projectTypeLabel}</p>
          <div class="flex items-center justify-between gap-4">
            <span id="project-type-label" class="font-medium text-(--text-primary) text-sm"></span>
            <span id="project-type-price" class="font-semibold text-(--accent) text-sm shrink-0"></span>
          </div>
        </div>

        <!-- Modules list -->
        <div
          id="modules-list"
          class="hidden mb-8"
          data-animate
          style="transition-delay: 240ms"
        >
          <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3 mt-6">{t.summary.modulesLabel}</p>
          <div id="modules-rows" class="space-y-2"></div>
        </div>

        <!-- CTA -->
        <div
          class="flex flex-col sm:flex-row gap-3 mt-8"
          data-animate
          style="transition-delay: 300ms"
        >
          <a
            href="/#contact"
            class="flex-1 text-center px-6 py-3 bg-(--accent) hover:bg-(--accent-bright) active:bg-(--accent-dim) text-(--on-accent) rounded-md font-semibold transition-colors shadow-md"
          >
            {t.summary.ctaLabel}
          </a>
          <a
            href="/arak/"
            class="flex-1 text-center px-6 py-3 border border-(--border-subtle) text-(--text-secondary) hover:border-(--accent) hover:text-(--accent) rounded-md font-semibold transition-colors"
          >
            {t.summary.backLink}
          </a>
        </div>

      </div>

    </div>
  </main>

  <Footer lang="hu" />
</Layout>

<script>
  // ── Adatok ──────────────────────────────────────────────────────────────────
  const PROJECT_TYPES: Record<string, { label: string; price: number; isFlat: boolean }> = {
    landing:      { label: "Landing page",           price: 0,      isFlat: false },
    portfolio:    { label: "Portfólió oldal",         price: 50000,  isFlat: false },
    corporate:    { label: "Céges bemutatkozó",       price: 80000,  isFlat: false },
    "blog-site":  { label: "Blog / magazin",          price: 60000,  isFlat: false },
    event:        { label: "Esemény / rendezvény",    price: 30000,  isFlat: false },
    webshop:      { label: "Webshop",                 price: 150000, isFlat: false },
    optimization: { label: "Weboldal optimalizálás",  price: 80000,  isFlat: true  },
  };

  const MODULES: Record<string, { label: string; cat: string }> = {
    "contact-form":        { label: "Kapcsolatfelvételi űrlap",                 cat: "Funkcionális modulok" },
    "blog":                { label: "Blog rendszer",                             cat: "Funkcionális modulok" },
    "gallery":             { label: "Képgaléria",                                cat: "Funkcionális modulok" },
    "webshop-cart":        { label: "Kosár és checkout",                         cat: "Funkcionális modulok" },
    "search":              { label: "Keresés",                                   cat: "Funkcionális modulok" },
    "auth":                { label: "Felhasználói regisztráció / bejelentkezés", cat: "Funkcionális modulok" },
    "booking":             { label: "Foglalási rendszer",                        cat: "Funkcionális modulok" },
    "newsletter":          { label: "Hírlevél feliratkozás",                     cat: "Funkcionális modulok" },
    "reviews":             { label: "Értékelés / vélemény rendszer",             cat: "Funkcionális modulok" },
    "payment":             { label: "Fizetési integráció",                       cat: "Funkcionális modulok" },
    "chatbot":             { label: "Chatbot / live chat integráció",            cat: "Funkcionális modulok" },
    "animations":          { label: "Egyedi animációk",                          cat: "Design modulok" },
    "dark-mode":           { label: "Sötét mód",                                 cat: "Design modulok" },
    "typography":          { label: "Egyedi tipográfia",                         cat: "Design modulok" },
    "illustrations":       { label: "Egyedi illusztrációk",                      cat: "Design modulok" },
    "parallax":            { label: "Parallax effektek",                         cat: "Design modulok" },
    "video-hero":          { label: "Videó hero szekció",                        cat: "Design modulok" },
    "map":                 { label: "Interaktív térkép",                         cat: "Design modulok" },
    "seo":                 { label: "SEO optimalizálás",                         cat: "Nem-funkcionális modulok" },
    "performance":         { label: "Teljesítmény optimalizálás",                cat: "Nem-funkcionális modulok" },
    "accessibility":       { label: "Akadálymentességi audit",                   cat: "Nem-funkcionális modulok" },
    "i18n":                { label: "Többnyelvűsítés (i18n)",                    cat: "Nem-funkcionális modulok" },
    "analytics":           { label: "Analytics integráció",                      cat: "Nem-funkcionális modulok" },
    "email-notifications": { label: "E-mail értesítések",                        cat: "Nem-funkcionális modulok" },
    "ssl":                 { label: "SSL beállítás",                             cat: "Biztonságkritikus modulok" },
    "gdpr":                { label: "GDPR megfelelőség",                         cat: "Biztonságkritikus modulok" },
    "spam-protection":     { label: "Spam védelem",                              cat: "Biztonságkritikus modulok" },
    "security-headers":    { label: "Biztonsági fejlécek",                       cat: "Biztonságkritikus modulok" },
    "backup":              { label: "Backup rendszer",                           cat: "Biztonságkritikus modulok" },
    "cookie-banner":       { label: "Cookie banner",                             cat: "Biztonságkritikus modulok" },
  };

  const OPTIONS: Record<string, string> = {
    "contact-basic":         "Alap form",
    "contact-multi":         "Többlépéses form",
    "contact-upload":        "Fájlfeltöltéssel",
    "blog-basic":            "Egyszerű blog",
    "blog-cats":             "Kategóriák + tagek",
    "blog-comments":         "Kommentrendszer",
    "blog-cms":              "Teljes CMS + szerkesztő",
    "gallery-basic":         "Alap galéria",
    "gallery-lightbox":      "Lightbox animációval",
    "gallery-portfolio":     "Portfolio + szűrő",
    "search-basic":          "Alap szöveges keresés",
    "search-filters":        "Szűrők + rendezés",
    "search-full":           "Teljes szöveges motor",
    "auth-email":            "Email / jelszó",
    "auth-social":           "Email + Social login",
    "booking-basic":         "Egyszerű foglalás",
    "booking-calendar":      "Naptár integrációval",
    "booking-payment":       "Fizetéssel integrálva",
    "newsletter-basic":      "Alap form",
    "newsletter-provider":   "Mailchimp / Brevo integrált",
    "payment-stripe":        "Stripe",
    "payment-barion":        "Barion",
    "payment-simplepay":     "SimplePay",
    "anim-subtle":           "Subtle – hover, fade",
    "anim-medium":           "Közepes – scroll, entrance",
    "anim-rich":             "Gazdag – micro-animations",
    "illus-icons":           "Ikon készlet",
    "illus-illus":           "Illusztrációk",
    "illus-identity":        "Vizuális identitás",
    "video-embed":           "Beágyazott (YouTube/Vimeo)",
    "video-custom":          "Egyedi háttérvideó",
    "seo-onpage":            "Alap on-page SEO",
    "seo-tech":              "Technikai SEO + schema.org",
    "seo-full":              "Teljes SEO audit + stratégia",
    "i18n-2":                "2 nyelv",
    "i18n-3":                "3 nyelv",
    "i18n-4":                "4+ nyelv",
    "analytics-ga4":         "GA4",
    "analytics-plausible":   "Plausible",
    "analytics-matomo":      "Matomo",
    "backup-weekly":         "Heti mentés",
    "backup-daily":          "Napi mentés",
    "backup-realtime":       "Valós idejű mentés",
  };

  const BASE = 150000;

  function formatHUF(n: number): string {
    return n.toLocaleString("hu-HU") + " Ft";
  }

  // ── URL paraméterek feldolgozása ────────────────────────────────────────────
  const params = new URLSearchParams(window.location.search);
  const typeIds = params.getAll("type");
  const rawModules = params.getAll("m");

  interface ParsedModule { id: string; optionId: string | null; price: number; }

  const projectTypes = typeIds.map(id => PROJECT_TYPES[id]).filter(Boolean);
  const hasFlat = projectTypes.some(t => t.isFlat);

  // Parse "moduleId:optionId" or just "moduleId"; derive price from URL total
  const totalFromUrl = parseInt(params.get("total") ?? "0", 10);

  const parsedModules: ParsedModule[] = rawModules
    .map((raw) => {
      const [id, optionId = null] = raw.split(":");
      return { id, optionId };
    })
    .filter(({ id }) => MODULES[id] && !hasFlat)
    .map(({ id, optionId }) => ({
      id,
      optionId,
      price: 0,
    }));

  // Re-derive total from URL param (already computed by calc page)
  const total = totalFromUrl || BASE;

  const hasContent = projectTypes.length > 0 || parsedModules.length > 0;

  // ── Megjelenítés ────────────────────────────────────────────────────────────
  if (!hasContent) {
    document.getElementById("summary-empty")?.classList.remove("hidden");
  } else {
    document.getElementById("summary-content")?.classList.remove("hidden");

    // Total
    const totalEl = document.getElementById("summary-total");
    if (totalEl) totalEl.textContent = formatHUF(total);

    // Project types
    if (projectTypes.length > 0) {
      const row = document.getElementById("project-type-row");
      const labelEl = document.getElementById("project-type-label");
      const priceEl = document.getElementById("project-type-price");
      row?.classList.remove("hidden");
      if (labelEl) labelEl.textContent = projectTypes.map(t => t.label).join(", ");
      if (priceEl) {
        if (hasFlat) {
          priceEl.textContent = formatHUF(projectTypes[0].price) + " (fix ár)";
        } else {
          const typesSum = projectTypes.reduce((a, t) => a + t.price, 0);
          priceEl.textContent = typesSum === 0 ? "Alap díj" : `+${formatHUF(typesSum)}`;
        }
      }
    }

    // Modules list
    if (parsedModules.length > 0) {
      document.getElementById("modules-list")?.classList.remove("hidden");
      const container = document.getElementById("modules-rows");
      if (container) {
        const grouped = new Map<string, ParsedModule[]>();
        parsedModules.forEach((pm) => {
          const cat = MODULES[pm.id].cat;
          if (!grouped.has(cat)) grouped.set(cat, []);
          grouped.get(cat)!.push(pm);
        });

        grouped.forEach((items, catLabel) => {
          const catHeader = document.createElement("p");
          catHeader.className = "text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mt-5 mb-2 first:mt-0";
          catHeader.textContent = catLabel;
          container.appendChild(catHeader);

          items.forEach(({ id, optionId }) => {
            const mod = MODULES[id];
            const optionLabel = optionId ? OPTIONS[optionId] : null;
            const row = document.createElement("div");
            row.className = "px-4 py-3 rounded-md border border-(--border-subtle) bg-white dark:bg-(--bg-surface)";
            row.style.cssText = "border-color: var(--border-subtle); background-color: var(--bg-base);";
            row.innerHTML = `
              <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem">
                <span style="font-size:0.875rem;font-weight:500;color:var(--text-primary)">${mod.label}</span>
              </div>
              ${optionLabel ? `<p style="font-size:0.75rem;color:var(--text-secondary);margin-top:2px">↳ ${optionLabel}</p>` : ""}
            `;
            container.appendChild(row);
          });
        });
      }
    }
  }

  // ── Felúszós animáció ───────────────────────────────────────────────────────
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
</script>
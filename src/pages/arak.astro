---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { hu as t } from "../i18n/hu";

const SITE = "https://levikaldor.hu";

const jsonld = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: t.pricing.metaTitle,
    url: `${SITE}/arak/`,
    inLanguage: "hu-HU",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Főoldal", item: `${SITE}/` },
      { "@type": "ListItem", position: 2, name: "Árak", item: `${SITE}/arak/` },
    ],
  },
];

function formatHUF(amount: number) {
  return amount.toLocaleString("hu-HU") + " Ft";
}
---

<Layout
  lang="hu"
  title={t.pricing.metaTitle}
  description={t.pricing.metaDescription}
  canonical={`${SITE}/arak/`}
  alternates={[
    { lang: "hu", href: `${SITE}/arak/` },
    { lang: "en", href: `${SITE}/en/pricing/` },
    { lang: "x-default", href: `${SITE}/arak/` },
  ]}
  jsonld={jsonld}
>
  <Navbar lang="hu" />

  <main class="pt-32 pb-16">
    <div class="max-w-3xl mx-auto px-4">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-10">
        <ol
          class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500"
        >
          <li>
            <a
              href="/"
              class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors"
              >Főoldal</a
            >
          </li>
          <li aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="M9 18l6-6-6-6"></path></svg
            >
          </li>
          <li>
            <span
              class="text-gray-600 dark:text-gray-300 font-medium"
              aria-current="page">{t.pricing.title}</span
            >
          </li>
        </ol>
      </nav>

      <h1 data-animate class="text-4xl font-bold text-gray-900 dark:text-white mb-3">
        {t.pricing.title}
      </h1>
      <p data-animate style="transition-delay: 80ms" class="text-lg text-gray-600 dark:text-gray-300 mb-10">
        {t.pricing.subtitle}
      </p>

      <!-- Alap díj kártya -->
      <div
        data-animate
        style="transition-delay: 140ms"
        class="mb-10 p-8 bg-indigo-50 dark:bg-indigo-900/20 rounded-2xl flex items-center justify-between gap-6"
      >
        <div>
          <p class="text-lg font-bold text-gray-900 dark:text-white">
            {t.pricing.baselineLabel}
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
            {t.pricing.baselineNote}
          </p>
        </div>
        <p
          class="text-3xl font-bold text-indigo-600 dark:text-indigo-400 shrink-0"
        >
          {formatHUF(t.pricing.baselineAmount)}
        </p>
      </div>

      <!-- Projekt típus -->
      <fieldset data-animate style="transition-delay: 200ms" data-stagger-section class="mb-10">
        <legend class="text-xl font-semibold text-gray-900 dark:text-white mb-4"
          >{t.pricing.projectTypeLabel}</legend
        >
        <div class="grid sm:grid-cols-2 gap-3 mb-4" id="project-type-group">
          {
            t.pricing.projectTypes.map((type) => (
              <label class="project-type-card stagger-card cursor-pointer flex items-center justify-between gap-3 p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 hover:border-indigo-400 dark:hover:border-indigo-500 transition-all">
                <div class="flex items-center gap-3">
                  <input
                    type="radio"
                    name="project-type"
                    value={type.id}
                    data-price={type.price}
                    data-flat={type.isFlat ? "true" : "false"}
                    class="accent-indigo-600 w-4 h-4 shrink-0"
                  />
                  <span class="font-medium text-gray-800 dark:text-gray-100">
                    {type.label}
                  </span>
                </div>
                <span class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 shrink-0">
                  {type.isFlat
                    ? formatHUF(type.price)
                    : type.price === 0
                      ? "Alap"
                      : `+${formatHUF(type.price)}`}
                </span>
              </label>
            ))
          }
        </div>

        <!-- Flat notice – slide animációval -->
        <div id="flat-notice" class="flat-notice">
          <div>
            <p class="text-sm text-amber-700 dark:text-amber-300 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 rounded-xl px-4 py-3">
              {t.pricing.flatNote}
            </p>
          </div>
        </div>
      </fieldset>

      <!-- Modul kategóriák -->
      <div id="modules-section">
        {
          t.pricing.categories.map((cat, i) => (
            <section
              data-animate
              style={`transition-delay: ${260 + i * 60}ms`}
              data-stagger-section
              class="mb-8"
            >
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">
                {cat.label}
              </h2>
              <div class="grid sm:grid-cols-2 gap-3">
                {cat.items.map((mod) => (
                  <label class="module-card stagger-card cursor-pointer flex items-center justify-between gap-3 p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 hover:border-indigo-400 dark:hover:border-indigo-500 transition-all">
                    <div class="flex items-center gap-3">
                      <input
                        type="checkbox"
                        name="module"
                        value={mod.id}
                        data-price={mod.price}
                        data-cat={cat.id}
                        class="accent-indigo-600 w-4 h-4 shrink-0"
                      />
                      <span class="font-medium text-gray-800 dark:text-gray-100 text-sm">
                        {mod.label}
                      </span>
                    </div>
                    <span class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 shrink-0">
                      +{formatHUF(mod.price)}
                    </span>
                  </label>
                ))}
              </div>
            </section>
          ))
        }
      </div>

      <!-- Felár figyelmeztetés -->
      <div
        data-animate
        style="transition-delay: 500ms"
        class="mt-4 mb-12 p-4 bg-amber-50 dark:bg-amber-900/20 rounded-xl border border-amber-200 dark:border-amber-700"
      >
        <p class="text-sm text-amber-800 dark:text-amber-200">
          {t.pricing.surchargeNotice}
        </p>
      </div>
    </div>
  </main>

  <!-- Sticky total bar -->
  <div
    id="total-bar"
    class="fixed bottom-0 left-0 right-0 z-30 border-t border-gray-200 dark:border-gray-700 px-4 py-4 total-bar-bg"
  >
    <div class="max-w-3xl mx-auto flex items-center justify-between gap-4">
      <div class="min-w-0">
        <p class="text-xs text-gray-500 dark:text-gray-400">
          {t.pricing.totalLabel}
        </p>
        <p
          id="total-display"
          class="text-2xl font-bold text-indigo-600 dark:text-indigo-400 leading-tight"
        >
          150 000 Ft
        </p>
        <p class="text-xs text-gray-400 dark:text-gray-500 truncate">
          {t.pricing.totalBaseline}
        </p>
      </div>
      <a
        id="cta-btn"
        href="/osszegzes/"
        class="shrink-0 self-center px-6 py-3 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white rounded-xl font-semibold text-sm transition-colors shadow-lg whitespace-nowrap"
      >
        {t.pricing.cta}
      </a>
    </div>
    <p class="max-w-3xl mx-auto text-xs text-gray-400 dark:text-gray-500 mt-2">
      {t.pricing.disclaimer}
    </p>
  </div>

  <Footer lang="hu" />
</Layout>

<style>
  /* ── Checkbox és radio ── */
  input[type="checkbox"],
  input[type="radio"] {
    accent-color: #6366f1;
    cursor: pointer;
  }

  /* ── Input pop animáció ── */
  @keyframes input-pop {
    0%   { transform: scale(0.6); }
    55%  { transform: scale(1.35); }
    80%  { transform: scale(0.9); }
    100% { transform: scale(1); }
  }

  input[type="checkbox"].just-checked,
  input[type="radio"].just-checked {
    animation: input-pop 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* ── Kártya pop animáció ── */
  @keyframes card-pop {
    0%   { transform: scale(1); }
    35%  { transform: scale(0.975); }
    65%  { transform: scale(1.015); }
    100% { transform: scale(1); }
  }

  .card-popping {
    animation: card-pop 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ── Modul kártyák ── */
  .module-card {
    transition:
      border-color 0.15s,
      background-color 0.15s,
      opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .module-card:has(input:checked) {
    border-color: #6366f1;
    background-color: #eef2ff;
  }
  :global(.dark) .module-card:has(input:checked) {
    background-color: rgba(99, 102, 241, 0.12);
    border-color: #6366f1;
  }
  .module-card:has(input:disabled) {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
    transform: scale(0.985);
  }

  /* ── Projekt típus kártyák ── */
  .project-type-card {
    transition:
      border-color 0.15s,
      background-color 0.15s;
  }
  .project-type-card:has(input:checked) {
    border-color: #6366f1;
    background-color: #eef2ff;
  }
  :global(.dark) .project-type-card:has(input:checked) {
    background-color: rgba(99, 102, 241, 0.12);
    border-color: #6366f1;
  }

  /* ── Flat notice slide ── */
  .flat-notice {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    margin-top: 0;
    transition:
      grid-template-rows 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      margin-top 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .flat-notice > div {
    overflow: hidden;
  }
  .flat-notice.is-visible {
    grid-template-rows: 1fr;
    opacity: 1;
    margin-top: 0.75rem;
  }

  /* ── Stagger card – belépő animáció ── */
  .stagger-card {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.15s,
      background-color 0.15s;
  }
  .stagger-card.card-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Counter roll animáció ── */
  @keyframes counter-up {
    0%   { transform: translateY(60%); opacity: 0; }
    100% { transform: translateY(0);   opacity: 1; }
  }
  @keyframes counter-down {
    0%   { transform: translateY(-60%); opacity: 0; }
    100% { transform: translateY(0);    opacity: 1; }
  }

  #total-display {
    overflow: hidden;
    display: block;
  }

  #total-display.roll-up {
    animation: counter-up 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #total-display.roll-down {
    animation: counter-down 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ── Total bar üveges háttér ── */
  .total-bar-bg {
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    box-shadow: 0 -1px 24px 0 rgba(0, 0, 0, 0.08);
  }
  :global(.dark) .total-bar-bg {
    background: rgba(2, 6, 23, 0.75);
    box-shadow: 0 -1px 24px 0 rgba(0, 0, 0, 0.4);
  }

  :global(footer) {
    padding-bottom: calc(2.5rem + 120px);
  }
</style>

<script>
  const BASE = 150000;

  interface ProjectType {
    id: string;
    price: number;
    isFlat: boolean;
  }

  let selectedProjectType: ProjectType | null = {
    id: "landing",
    price: 0,
    isFlat: false,
  };
  const selectedModules = new Map<string, number>();
  let currentTotal = BASE;

  // ── Formázás ────────────────────────────────────────────────────────────────
  function formatHUF(n: number): string {
    return n.toLocaleString("hu-HU") + " Ft";
  }

  // ── Animated counter ────────────────────────────────────────────────────────
  function animateCounter(newTotal: number) {
    const display = document.getElementById("total-display");
    if (!display) return;

    const direction = newTotal > currentTotal ? "roll-up" : "roll-down";
    currentTotal = newTotal;

    display.classList.remove("roll-up", "roll-down");
    // force reflow
    void (display as HTMLElement).offsetWidth;
    display.textContent = formatHUF(newTotal);
    display.classList.add(direction);

    display.addEventListener("animationend", () => {
      display.classList.remove("roll-up", "roll-down");
    }, { once: true });
  }

  // ── Total számítás ──────────────────────────────────────────────────────────
  function calculateTotal(): number {
    if (selectedProjectType?.isFlat) return selectedProjectType.price;
    const projectAdd = selectedProjectType?.price ?? 0;
    const modulesSum = [...selectedModules.values()].reduce((a, b) => a + b, 0);
    return BASE + projectAdd + modulesSum;
  }

  function updateDisplay() {
    const newTotal = calculateTotal();
    if (newTotal !== currentTotal) {
      animateCounter(newTotal);
    }

    const params = new URLSearchParams();
    if (selectedProjectType) params.set("type", selectedProjectType.id);
    selectedModules.forEach((_, id) => params.append("m", id));
    params.set("total", String(newTotal));

    const btn = document.getElementById("cta-btn") as HTMLAnchorElement | null;
    if (btn) btn.href = "/osszegzes/?" + params.toString();
  }

  // ── Modulok letiltása/engedélyezése ────────────────────────────────────────
  function setModulesDisabled(disabled: boolean) {
    document
      .querySelectorAll<HTMLInputElement>("input[name='module']")
      .forEach((el) => {
        el.disabled = disabled;
        if (disabled) el.checked = false;
      });
    if (disabled) selectedModules.clear();

    const notice = document.getElementById("flat-notice");
    if (notice) {
      if (disabled) {
        notice.classList.add("is-visible");
      } else {
        notice.classList.remove("is-visible");
      }
    }
  }

  // ── Card pop animáció ────────────────────────────────────────────────────────
  function triggerCardPop(label: HTMLElement, input: HTMLInputElement) {
    label.classList.remove("card-popping");
    void label.offsetWidth;
    label.classList.add("card-popping");
    label.addEventListener("animationend", () => {
      label.classList.remove("card-popping");
    }, { once: true });

    input.classList.remove("just-checked");
    void input.offsetWidth;
    input.classList.add("just-checked");
    input.addEventListener("animationend", () => {
      input.classList.remove("just-checked");
    }, { once: true });
  }

  // ── Event handlers ──────────────────────────────────────────────────────────
  function onProjectTypeChange(e: Event) {
    const input = e.target as HTMLInputElement;
    const label = input.closest("label") as HTMLElement;

    selectedProjectType = {
      id: input.value,
      price: parseInt(input.dataset.price ?? "0", 10),
      isFlat: input.dataset.flat === "true",
    };

    triggerCardPop(label, input);
    setModulesDisabled(selectedProjectType.isFlat);
    updateDisplay();
  }

  function onModuleChange(e: Event) {
    const input = e.target as HTMLInputElement;
    const label = input.closest("label") as HTMLElement;
    const price = parseInt(input.dataset.price ?? "0", 10);

    if (input.checked) {
      selectedModules.set(input.value, price);
      triggerCardPop(label, input);
    } else {
      selectedModules.delete(input.value);
    }
    updateDisplay();
  }

  // ── Wire up events ──────────────────────────────────────────────────────────
  document
    .querySelectorAll<HTMLInputElement>("input[name='project-type']")
    .forEach((el) => el.addEventListener("change", onProjectTypeChange));

  document
    .querySelectorAll<HTMLInputElement>("input[name='module']")
    .forEach((el) => el.addEventListener("change", onModuleChange));

  // ── Init: landing alapértelmezett ────────────────────────────────────────────
  const firstRadio = document.querySelector<HTMLInputElement>(
    "input[name='project-type'][value='landing']",
  );
  if (firstRadio) firstRadio.checked = true;
  currentTotal = BASE;
  const display = document.getElementById("total-display");
  if (display) display.textContent = formatHUF(BASE);

  // ── Scroll-to-top gomb felemelése mobilon ────────────────────────────────────
  const scrollBtn = document.getElementById("scroll-top");
  const totalBar = document.getElementById("total-bar");
  if (scrollBtn && totalBar) {
    const ro = new ResizeObserver(() => {
      if (window.innerWidth < 768) {
        scrollBtn.style.bottom = (totalBar.offsetHeight + 12) + "px";
      } else {
        scrollBtn.style.bottom = "";
      }
    });
    ro.observe(totalBar);
    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768) scrollBtn.style.bottom = "";
    }, { passive: true });
  }

  // ── Scroll-in animáció (data-animate) ────────────────────────────────────────
  const animObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          animObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll("[data-animate]").forEach((el) => animObserver.observe(el));

  // ── Staggered kártyák ────────────────────────────────────────────────────────
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const cards = entry.target.querySelectorAll<HTMLElement>(".stagger-card");
        cards.forEach((card, i) => {
          setTimeout(() => {
            card.classList.add("card-visible");
          }, i * 60);
        });
        sectionObserver.unobserve(entry.target);
      });
    },
    { threshold: 0.05 }
  );
  document.querySelectorAll("[data-stagger-section]").forEach((el) => sectionObserver.observe(el));
</script>
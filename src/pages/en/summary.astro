---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { en as t } from "../../i18n/en";

const SITE = "https://levikaldor.hu";
---

<Layout
  lang="en"
  title={t.summary.metaTitle}
  description={t.summary.metaDescription}
  canonical={`${SITE}/en/summary/`}
  noindex={true}
>
  <Navbar lang="en" />

  <main class="pt-32 pb-20 min-h-[calc(100vh-var(--footer-h,80px))]">
    <div class="max-w-3xl mx-auto px-4">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-10" data-animate style="transition-delay: 0ms">
        <ol class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500">
          <li>
            <a href="/en/" class="hover:text-(--accent) transition-colors">Home</a>
          </li>
          <li aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </li>
          <li>
            <a href="/en/pricing/" class="hover:text-(--accent) transition-colors">{t.summary.breadcrumbPricing}</a>
          </li>
          <li aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </li>
          <li>
            <span class="text-(--text-secondary) font-medium" aria-current="page">{t.summary.breadcrumbSummary}</span>
          </li>
        </ol>
      </nav>

      <h1
        class="text-4xl md:text-5xl font-bold text-(--text-primary) mb-10"
        data-animate
        style="transition-delay: 60ms"
      >
        {t.summary.title}
      </h1>

      <noscript>
        <meta http-equiv="refresh" content="0;url=/en/pricing/" />
        <p class="text-(--text-secondary)">JavaScript is required. <a href="/en/pricing/" class="text-(--accent) underline">Back to the pricing calculator.</a></p>
      </noscript>

      <!-- Empty state -->
      <div id="summary-empty" class="hidden text-center py-20" data-animate style="transition-delay: 120ms">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-lg bg-gray-100 dark:bg-gray-800 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 dark:text-gray-500"><path d="M9 14l-4-4 4-4"/><path d="M5 10h11a4 4 0 0 1 0 8h-1"/></svg>
        </div>
        <p class="text-(--text-secondary) mb-6 text-lg">{t.summary.empty}</p>
        <a href="/en/pricing/" class="inline-block px-6 py-3 bg-(--accent) hover:bg-(--accent-bright) text-white rounded-md font-semibold transition-colors">
          {t.summary.backLink}
        </a>
      </div>

      <!-- Summary content -->
      <div id="summary-content" class="hidden">

        <!-- Total card -->
        <div
          class="mb-6 p-8 bg-(--accent-bg) border border-(--accent-border) rounded-lg flex items-center justify-between gap-6"
          data-animate
          style="transition-delay: 120ms"
        >
          <div>
            <p class="text-lg font-bold text-(--text-primary)">{t.summary.totalLabel}</p>
            <p class="text-sm text-gray-400 dark:text-gray-500 mt-0.5">{t.summary.disclaimer}</p>
          </div>
          <p id="summary-total" class="text-3xl font-bold text-(--accent) shrink-0"></p>
        </div>

        <!-- Project type -->
        <div
          id="project-type-row"
          class="hidden mb-3 p-4 rounded-md border border-(--border-subtle) bg-white dark:bg-(--bg-surface)"
          data-animate
          style="transition-delay: 180ms"
        >
          <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3">{t.summary.projectTypeLabel}</p>
          <div class="flex items-center justify-between gap-4">
            <span id="project-type-label" class="font-medium text-(--text-primary) text-sm"></span>
            <span id="project-type-price" class="font-semibold text-(--accent) text-sm shrink-0"></span>
          </div>
        </div>

        <!-- Modules list -->
        <div
          id="modules-list"
          class="hidden mb-8"
          data-animate
          style="transition-delay: 240ms"
        >
          <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-3 mt-6">{t.summary.modulesLabel}</p>
          <div id="modules-rows" class="space-y-2"></div>
        </div>

        <!-- CTA -->
        <div
          class="flex flex-col sm:flex-row gap-3 mt-8"
          data-animate
          style="transition-delay: 300ms"
        >
          <a
            href={t.summary.ctaHref}
            class="flex-1 text-center px-6 py-3 bg-(--accent) hover:bg-(--accent-bright) active:bg-(--accent-dim) text-white rounded-md font-semibold transition-colors shadow-md"
          >
            {t.summary.ctaLabel}
          </a>
          <a
            href="/en/pricing/"
            class="flex-1 text-center px-6 py-3 border border-(--border-subtle) text-(--text-secondary) hover:border-(--accent) hover:text-(--accent) rounded-md font-semibold transition-colors"
          >
            {t.summary.backLink}
          </a>
        </div>

      </div>

    </div>
  </main>

  <Footer lang="en" />
</Layout>

<script>
  // ── Data ────────────────────────────────────────────────────────────────────
  const PROJECT_TYPES: Record<string, { label: string; price: number; isFlat: boolean }> = {
    landing:      { label: "Landing page",          price: 0,      isFlat: false },
    portfolio:    { label: "Portfolio website",      price: 50000,  isFlat: false },
    corporate:    { label: "Company website",        price: 80000,  isFlat: false },
    "blog-site":  { label: "Blog / magazine",        price: 60000,  isFlat: false },
    event:        { label: "Event / conference",     price: 30000,  isFlat: false },
    webshop:      { label: "Webshop",                price: 150000, isFlat: false },
    optimization: { label: "Website optimisation",  price: 80000,  isFlat: true  },
  };

  const MODULES: Record<string, { label: string; cat: string }> = {
    "contact-form":        { label: "Contact form",                   cat: "Functional modules" },
    "blog":                { label: "Blog system",                    cat: "Functional modules" },
    "gallery":             { label: "Image gallery",                  cat: "Functional modules" },
    "webshop-cart":        { label: "Cart & checkout",                cat: "Functional modules" },
    "search":              { label: "Search",                         cat: "Functional modules" },
    "auth":                { label: "User registration / login",      cat: "Functional modules" },
    "booking":             { label: "Booking system",                 cat: "Functional modules" },
    "newsletter":          { label: "Newsletter subscription",        cat: "Functional modules" },
    "reviews":             { label: "Reviews / testimonials system",  cat: "Functional modules" },
    "payment":             { label: "Payment integration",            cat: "Functional modules" },
    "chatbot":             { label: "Chatbot / live chat",            cat: "Functional modules" },
    "animations":          { label: "Custom animations",              cat: "Design modules" },
    "dark-mode":           { label: "Dark mode",                      cat: "Design modules" },
    "typography":          { label: "Custom typography",              cat: "Design modules" },
    "illustrations":       { label: "Custom illustrations",           cat: "Design modules" },
    "parallax":            { label: "Parallax effects",               cat: "Design modules" },
    "video-hero":          { label: "Video hero section",             cat: "Design modules" },
    "map":                 { label: "Interactive map",                cat: "Design modules" },
    "seo":                 { label: "SEO optimisation",               cat: "Non-functional modules" },
    "performance":         { label: "Performance optimisation",       cat: "Non-functional modules" },
    "accessibility":       { label: "Accessibility audit",            cat: "Non-functional modules" },
    "i18n":                { label: "Multilingual (i18n)",            cat: "Non-functional modules" },
    "analytics":           { label: "Analytics integration",          cat: "Non-functional modules" },
    "email-notifications": { label: "Email notifications",            cat: "Non-functional modules" },
    "ssl":                 { label: "SSL setup",                      cat: "Security-critical modules" },
    "gdpr":                { label: "GDPR compliance",                cat: "Security-critical modules" },
    "spam-protection":     { label: "Spam protection",                cat: "Security-critical modules" },
    "security-headers":    { label: "Security headers",               cat: "Security-critical modules" },
    "backup":              { label: "Backup system",                  cat: "Security-critical modules" },
    "cookie-banner":       { label: "Cookie banner",                  cat: "Security-critical modules" },
  };

  const OPTIONS: Record<string, string> = {
    "contact-basic":         "Basic form",
    "contact-multi":         "Multi-step form",
    "contact-upload":        "With file upload",
    "blog-basic":            "Simple blog",
    "blog-cats":             "Categories + tags",
    "blog-comments":         "Comment system",
    "blog-cms":              "Full CMS + editor",
    "gallery-basic":         "Basic gallery",
    "gallery-lightbox":      "Lightbox animated",
    "gallery-portfolio":     "Portfolio + filter",
    "search-basic":          "Basic text search",
    "search-filters":        "Filters + sorting",
    "search-full":           "Full-text engine",
    "auth-email":            "Email / password",
    "auth-social":           "Email + Social login",
    "booking-basic":         "Simple booking",
    "booking-calendar":      "With calendar",
    "booking-payment":       "With payment",
    "newsletter-basic":      "Basic form",
    "newsletter-provider":   "Mailchimp / Brevo integrated",
    "payment-stripe":        "Stripe",
    "payment-barion":        "Barion",
    "payment-simplepay":     "SimplePay",
    "anim-subtle":           "Subtle – hover, fade",
    "anim-medium":           "Medium – scroll, entrance",
    "anim-rich":             "Rich – micro-animations",
    "illus-icons":           "Icon set",
    "illus-illus":           "Illustrations",
    "illus-identity":        "Visual identity",
    "video-embed":           "Embedded (YouTube/Vimeo)",
    "video-custom":          "Custom background video",
    "seo-onpage":            "Basic on-page SEO",
    "seo-tech":              "Technical SEO + schema.org",
    "seo-full":              "Full SEO audit + strategy",
    "i18n-2":                "2 languages",
    "i18n-3":                "3 languages",
    "i18n-4":                "4+ languages",
    "analytics-ga4":         "GA4",
    "analytics-plausible":   "Plausible",
    "analytics-matomo":      "Matomo",
    "backup-weekly":         "Weekly backup",
    "backup-daily":          "Daily backup",
    "backup-realtime":       "Real-time backup",
  };

  const BASE = 150000;

  function formatHUF(n: number): string {
    return n.toLocaleString("hu-HU") + " Ft";
  }

  // ── Parse URL params ────────────────────────────────────────────────────────
  const params = new URLSearchParams(window.location.search);
  const typeIds = params.getAll("type");
  const rawModules = params.getAll("m");

  interface ParsedModule { id: string; optionId: string | null; }

  const projectTypes = typeIds.map(id => PROJECT_TYPES[id]).filter(Boolean);
  const hasFlat = projectTypes.some(t => t.isFlat);
  const totalFromUrl = parseInt(params.get("total") ?? "0", 10);

  const parsedModules: ParsedModule[] = rawModules
    .map((raw) => {
      const [id, optionId = null] = raw.split(":");
      return { id, optionId };
    })
    .filter(({ id }) => MODULES[id] && !hasFlat);

  const total = totalFromUrl || BASE;
  const hasContent = projectTypes.length > 0 || parsedModules.length > 0;

  // ── Render ──────────────────────────────────────────────────────────────────
  if (!hasContent) {
    document.getElementById("summary-empty")?.classList.remove("hidden");
  } else {
    document.getElementById("summary-content")?.classList.remove("hidden");

    const totalEl = document.getElementById("summary-total");
    if (totalEl) totalEl.textContent = formatHUF(total);

    if (projectTypes.length > 0) {
      const row = document.getElementById("project-type-row");
      const labelEl = document.getElementById("project-type-label");
      const priceEl = document.getElementById("project-type-price");
      row?.classList.remove("hidden");
      if (labelEl) labelEl.textContent = projectTypes.map(t => t.label).join(", ");
      if (priceEl) {
        if (hasFlat) {
          priceEl.textContent = formatHUF(projectTypes[0].price) + " (fixed price)";
        } else {
          const typesSum = projectTypes.reduce((a, t) => a + t.price, 0);
          priceEl.textContent = typesSum === 0 ? "Base fee" : `+${formatHUF(typesSum)}`;
        }
      }
    }

    if (parsedModules.length > 0) {
      document.getElementById("modules-list")?.classList.remove("hidden");
      const container = document.getElementById("modules-rows");
      if (container) {
        const grouped = new Map<string, ParsedModule[]>();
        parsedModules.forEach((pm) => {
          const cat = MODULES[pm.id].cat;
          if (!grouped.has(cat)) grouped.set(cat, []);
          grouped.get(cat)!.push(pm);
        });

        grouped.forEach((items, catLabel) => {
          const catHeader = document.createElement("p");
          catHeader.className = "text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mt-5 mb-2 first:mt-0";
          catHeader.textContent = catLabel;
          container.appendChild(catHeader);

          items.forEach(({ id, optionId }) => {
            const mod = MODULES[id];
            const optionLabel = optionId ? OPTIONS[optionId] : null;
            const row = document.createElement("div");
            row.className = "px-4 py-3 rounded-md";
            row.style.cssText = "border: 1px solid var(--border-subtle); background-color: var(--bg-base);";
            row.innerHTML = `
              <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem">
                <span style="font-size:0.875rem;font-weight:500;color:var(--text-primary)">${mod.label}</span>
              </div>
              ${optionLabel ? `<p style="font-size:0.75rem;color:var(--text-secondary);margin-top:2px">↳ ${optionLabel}</p>` : ""}
            `;
            container.appendChild(row);
          });
        });
      }
    }
  }

  // ── Scroll-in animation ─────────────────────────────────────────────────────
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
</script>
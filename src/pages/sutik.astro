---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  lang="hu"
  title="Cookie tájékoztató | Káldor Levente"
  description="Cookie (süti) tájékoztató – Káldor Levente webfejlesztő."
  canonical="https://levikaldor.hu/sutik/"
>
  <Navbar lang="hu" />

  <main class="pt-32 pb-20">
    <div class="max-w-3xl mx-auto px-4">
      <nav aria-label="Breadcrumb" class="mb-10">
        <ol class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500">
          <li>
            <a href="/" class="hover:text-(--accent) transition-colors">Főoldal</a>
          </li>
          <li aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </li>
          <li>
            <span class="text-gray-600 dark:text-gray-300 font-medium" aria-current="page">Cookie tájékoztató</span>
          </li>
        </ol>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6 mb-12">
        <div>
          <h1 class="text-4xl md:text-5xl font-bold text-(--text-primary) mb-4">
            Süti tájékoztató
          </h1>
          <p class="text-(--text-secondary) text-lg">
            Utoljára frissítve: 2026. április 18.
          </p>
        </div>
        <a
          href="/docs/sutik.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 shrink-0 px-5 py-3 border border-(--border-subtle) rounded-lg text-(--text-secondary) hover:text-(--accent) hover:border-(--accent) transition-colors text-sm font-medium"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="12" y1="18" x2="12" y2="12"/>
            <line x1="9" y1="15" x2="15" y2="15"/>
          </svg>
          PDF letöltése
        </a>
      </div>

      <div class="space-y-8 text-(--text-secondary) leading-relaxed">

        <section>
          <h2 class="text-xl font-semibold text-(--text-primary) mb-3">Mi az a süti?</h2>
          <p>
            A süti (cookie) egy kis szöveges fájl, amelyet a weboldal a böngésződben tárol.
            Segítségével az oldal megjegyezheti a beállításaidat és javíthatja a felhasználói élményt.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-(--text-primary) mb-3">Milyen sütiket használunk?</h2>

          <div class="space-y-4 mt-4">
            <div class="border border-(--border-subtle) rounded-lg p-5">
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-medium text-(--text-primary)">Szükséges sütik</h3>
                <span class="text-xs px-2 py-1 bg-green-500/10 text-green-600 dark:text-green-400 rounded-full">Mindig aktív</span>
              </div>
              <p class="text-sm">
                A weboldal alapvető működéséhez elengedhetetlenek. Ezeket nem lehet letiltani.
              </p>
              <p class="text-sm mt-2 text-(--text-tertiary)">[Placeholder: konkrét sütik listája]</p>
            </div>

            <div class="border border-(--border-subtle) rounded-lg p-5">
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-medium text-(--text-primary)">Analitikai sütik</h3>
                <span class="text-xs px-2 py-1 bg-yellow-500/10 text-yellow-600 dark:text-yellow-400 rounded-full">Opcionális</span>
              </div>
              <p class="text-sm">
                Segítenek megérteni, hogyan használják a látogatók az oldalt (pl. Google Analytics).
                Anonim statisztikai adatokat gyűjtenek.
              </p>
              <p class="text-sm mt-2 text-(--text-tertiary)">[Placeholder: jelenleg nem aktív / konkrét sütik listája]</p>
            </div>
          </div>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-(--text-primary) mb-3">Hogyan kezelheted a sütiket?</h2>
          <p>
            A legtöbb böngésző alapértelmezetten elfogadja a sütiket, de beállításaidban
            bármikor módosíthatod vagy törölheted őket. Fontos: a szükséges sütik letiltása
            az oldal működését ronthatja.
          </p>
          <ul class="list-disc list-inside space-y-1 mt-3 text-sm">
            <li><a href="https://support.google.com/chrome/answer/95647" target="_blank" rel="noopener noreferrer" class="text-(--accent) hover:underline">Google Chrome</a></li>
            <li><a href="https://support.mozilla.org/hu/kb/sutik-engedelyezese-es-tiltasa" target="_blank" rel="noopener noreferrer" class="text-(--accent) hover:underline">Mozilla Firefox</a></li>
            <li><a href="https://support.apple.com/hu-hu/guide/safari/sfri11471/mac" target="_blank" rel="noopener noreferrer" class="text-(--accent) hover:underline">Safari</a></li>
            <li><a href="https://support.microsoft.com/hu-hu/microsoft-edge/sütik-törlése-a-microsoft-edge-ben" target="_blank" rel="noopener noreferrer" class="text-(--accent) hover:underline">Microsoft Edge</a></li>
          </ul>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-(--text-primary) mb-3">További információ</h2>
          <p>
            Az adatkezelésről részletesen az
            <a href="/adatvedelem/" class="text-(--accent) hover:underline">Adatvédelmi tájékoztatóban</a> olvashatsz.
          </p>
        </section>

        <section class="border border-(--border-subtle) rounded-lg p-6">
          <h2 class="text-xl font-semibold text-(--text-primary) mb-2">Hozzájárulás kezelése</h2>
          <p class="text-sm text-(--text-secondary) mb-5">
            Az alábbi gombokkal bármikor módosíthatod a süti-beállításodat.
            Jelenlegi állapot: <span id="cookie-status" class="font-medium text-(--text-primary)">–</span>
          </p>
          <div class="flex flex-wrap gap-3">
            <button
              id="cookie-page-accept"
              class="px-4 py-2 text-sm rounded-lg bg-(--accent) text-(--on-accent) font-medium hover:bg-(--accent-bright) transition-colors"
            >
              Elfogadom az összes sütit
            </button>
            <button
              id="cookie-page-decline"
              class="px-4 py-2 text-sm rounded-lg border border-(--border-subtle) text-(--text-secondary) hover:border-(--text-tertiary) transition-colors"
            >
              Csak szükségesek
            </button>
            <button
              id="cookie-page-reset"
              class="px-4 py-2 text-sm rounded-lg border border-(--border-subtle) text-(--text-tertiary) hover:border-(--text-tertiary) transition-colors"
            >
              Visszaállítás
            </button>
          </div>
        </section>

      </div>

      <script>
        const STORAGE_KEY = "kl-cookies";
        const statusEl = document.getElementById("cookie-status");

        const labels: Record<string, string> = {
          accepted: "Elfogadva",
          declined: "Elutasítva",
        };

        function updateStatus() {
          const val = localStorage.getItem(STORAGE_KEY);
          if (statusEl) statusEl.textContent = val ? (labels[val] ?? val) : "Nincs megadva";
        }
        updateStatus();

        document.getElementById("cookie-page-accept")?.addEventListener("click", () => {
          localStorage.setItem(STORAGE_KEY, "accepted");
          updateStatus();
        });
        document.getElementById("cookie-page-decline")?.addEventListener("click", () => {
          localStorage.setItem(STORAGE_KEY, "declined");
          updateStatus();
        });
        document.getElementById("cookie-page-reset")?.addEventListener("click", () => {
          localStorage.removeItem(STORAGE_KEY);
          updateStatus();
        });
      </script>

      <div class="mt-16 p-8 bg-(--accent-bg) border border-(--accent-border) rounded-lg text-center">
        <h2 class="text-xl font-bold text-(--text-primary) mb-2">Kérdésed van?</h2>
        <p class="text-(--text-secondary) mb-6">Írj nekem és személyesen válaszolok.</p>
        <a href="/#contact" class="inline-block px-6 py-3 bg-(--accent) text-(--on-accent) rounded-md font-medium hover:bg-(--accent-bright) transition-colors">
          Kapcsolatfelvétel
        </a>
      </div>
    </div>
  </main>

  <Footer lang="hu" />
</Layout>

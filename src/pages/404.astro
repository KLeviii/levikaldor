---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  lang="hu"
  title="404 – Az oldal nem található | Káldor Levente"
  description="A keresett oldal nem létezik vagy el lett távolítva."
  noindex={true}
>
  <Navbar lang="hu" />

  <div class="min-h-[calc(100vh-65px)] flex items-center justify-center px-4 pt-32 pb-20">
    <div class="text-center max-w-lg mx-auto" data-animate>
      <p class="font-bold text-(--accent) mb-6 leading-none select-none" style="font-size: clamp(6rem, 15vw, 12rem);">404</p>
      <h1 class="text-3xl font-bold text-(--text-primary) mb-4">Az oldal nem található</h1>
      <p class="text-(--text-secondary) mb-8 text-lg">
        A keresett oldal nem létezik, vagy el lett távolítva. Lehet, hogy a link elavult?
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-(--accent) hover:bg-(--accent-bright) text-(--on-accent) font-semibold rounded-xl transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Vissza a főoldalra
        </a>
        <a
          href="/#contact"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-(--border) hover:border-(--accent) text-(--text-primary) font-semibold rounded-xl transition-colors"
        >
          Kapcsolatfelvétel
        </a>
      </div>
    </div>
  </div>

  <Footer lang="hu" />
</Layout>

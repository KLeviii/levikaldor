---
export const prerender = false;

import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase';

const supabase = createSupabaseServerClient(Astro.cookies);

const readId = Astro.url.searchParams.get('read');
if (readId) {
  await supabase.from('contact_messages').update({ is_read: true }).eq('id', readId);
  return Astro.redirect('/admin/messages/');
}

const { data: messages } = await supabase
  .from('contact_messages')
  .select('*')
  .order('created_at', { ascending: false });

const unreadCount = messages?.filter(m => !m.is_read).length ?? 0;
---

<AdminLayout title="Üzenetek" activePage="messages">
  <div class="flex items-center gap-3 mb-6">
    <p class="text-sm text-(--text-secondary)">{messages?.length ?? 0} üzenet összesen</p>
    {unreadCount > 0 && (
      <span class="px-2 py-0.5 bg-(--accent-bg) text-(--accent) border border-(--accent-border) text-xs font-semibold rounded-full">
        {unreadCount} olvasatlan
      </span>
    )}
  </div>

  <div class="space-y-3">
    {!messages?.length ? (
      <div class="text-center py-16 text-(--text-tertiary) text-sm">
        Még nem érkezett üzenet.
      </div>
    ) : (
      messages.map((msg) => (
        <div class={`bg-(--bg-surface) border rounded-lg p-4 transition-colors
          ${!msg.is_read ? 'border-(--accent-border) bg-(--accent-bg)/40' : 'border-(--border-subtle)'}`}>
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                {!msg.is_read && (
                  <span class="inline-block w-2 h-2 rounded-full bg-(--accent) shrink-0"></span>
                )}
                <span class="font-semibold text-(--text-primary)">{msg.name}</span>
                <span class="px-1.5 py-0.5 bg-(--bg-elevated) border border-(--border-subtle) text-(--text-tertiary) text-xs rounded font-mono">
                  {msg.lang.toUpperCase()}
                </span>
              </div>
              <a href={`mailto:${msg.email}`}
                class="text-sm text-(--accent) hover:text-(--accent-bright) transition-colors block mb-2">
                {msg.email}
              </a>
              <p class="text-sm text-(--text-secondary) leading-relaxed whitespace-pre-wrap">{msg.message}</p>
            </div>
            <div class="flex flex-col items-end gap-2 shrink-0">
              <time class="text-xs text-(--text-tertiary) whitespace-nowrap">
                {new Date(msg.created_at).toLocaleDateString('hu-HU', {
                  year: 'numeric', month: 'short', day: 'numeric',
                  hour: '2-digit', minute: '2-digit'
                })}
              </time>
              {!msg.is_read && (
                <a href={`/admin/messages/?read=${msg.id}`}
                  class="text-xs text-(--text-secondary) hover:text-(--text-primary) transition-colors underline underline-offset-2">
                  Olvasottnak jelöl
                </a>
              )}
            </div>
          </div>
        </div>
      ))
    )}
  </div>
</AdminLayout>

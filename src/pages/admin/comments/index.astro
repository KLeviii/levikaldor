---
export const prerender = false;

import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase';

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action')?.toString();
  const id = form.get('id')?.toString();

  if (id) {
    if (action === 'approve') {
      await supabase.from('blog_comments').update({ is_approved: true }).eq('id', id);
    } else if (action === 'unapprove') {
      await supabase.from('blog_comments').update({ is_approved: false }).eq('id', id);
    } else if (action === 'delete') {
      await supabase.from('blog_comments').delete().eq('id', id);
    }
  }
  return Astro.redirect('/admin/comments/');
}

const filter = Astro.url.searchParams.get('filter') ?? 'pending';
const showAll = filter === 'all';

let query = supabase
  .from('blog_comments')
  .select('id, post_slug, name, email, content, is_approved, created_at')
  .order('created_at', { ascending: false });

if (!showAll) query = query.eq('is_approved', false);

const { data: comments } = await query;

const { count: pendingCount } = await supabase
  .from('blog_comments')
  .select('*', { count: 'exact', head: true })
  .eq('is_approved', false);
---

<AdminLayout title="Hozzászólások" activePage="comments">
  <div class="space-y-6">

    <!-- Tabs -->
    <div class="flex items-center gap-1 border-b border-(--border-subtle)">
      <a href="/admin/comments/?filter=pending"
        class={`px-4 py-2.5 text-sm font-medium border-b-2 -mb-px transition-colors flex items-center gap-2
          ${!showAll
            ? 'border-(--accent) text-(--accent)'
            : 'border-transparent text-(--text-secondary) hover:text-(--text-primary)'}`}>
        Várakozó
        {(pendingCount ?? 0) > 0 && (
          <span class="px-1.5 py-0.5 rounded-full text-xs font-bold bg-(--accent) text-(--on-accent)">{pendingCount}</span>
        )}
      </a>
      <a href="/admin/comments/?filter=all"
        class={`px-4 py-2.5 text-sm font-medium border-b-2 -mb-px transition-colors
          ${showAll
            ? 'border-(--accent) text-(--accent)'
            : 'border-transparent text-(--text-secondary) hover:text-(--text-primary)'}`}>
        Összes
      </a>
    </div>

    <!-- Empty state -->
    {(!comments || comments.length === 0) && (
      <div class="text-center py-16 text-(--text-tertiary)">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto mb-3 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <p class="text-sm">{showAll ? 'Még nincs hozzászólás.' : 'Nincs várakozó hozzászólás.'}</p>
      </div>
    )}

    <!-- Comment list -->
    <div class="space-y-3">
      {(comments ?? []).map(c => {
        const letter = c.name.charAt(0).toUpperCase();
        const date = new Date(c.created_at).toLocaleString('hu-HU', {
          year: 'numeric', month: 'short', day: 'numeric',
          hour: '2-digit', minute: '2-digit',
        });
        return (
          <div class={`bg-(--bg-surface) border rounded-lg p-4 ${c.is_approved ? 'border-(--border-subtle)' : 'border-amber-300 dark:border-amber-700'}`}>
            <div class="flex items-start gap-3">
              <span class="w-9 h-9 rounded-full bg-(--accent) text-(--on-accent) text-sm font-bold flex items-center justify-center shrink-0 select-none">
                {letter}
              </span>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mb-1">
                  <span class="text-sm font-semibold text-(--text-primary)">{c.name}</span>
                  {c.email && <span class="text-xs text-(--text-tertiary)">{c.email}</span>}
                  <span class="text-xs text-(--text-tertiary)">·</span>
                  <time class="text-xs text-(--text-tertiary)">{date}</time>
                  <span class="text-xs text-(--text-tertiary)">·</span>
                  <a href={`/blog/${c.post_slug}/`} target="_blank"
                    class="text-xs text-(--accent) hover:underline truncate max-w-[200px]">
                    /blog/{c.post_slug}/
                  </a>
                  {!c.is_approved && (
                    <span class="px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">
                      Várakozó
                    </span>
                  )}
                </div>
                <p class="text-sm text-(--text-secondary) leading-relaxed whitespace-pre-wrap">{c.content}</p>
              </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-2 mt-3 ml-12">
              {!c.is_approved ? (
                <form method="POST">
                  <input type="hidden" name="id" value={c.id} />
                  <input type="hidden" name="action" value="approve" />
                  <button type="submit"
                    class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs font-medium rounded-md transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Jóváhagyás
                  </button>
                </form>
              ) : (
                <form method="POST">
                  <input type="hidden" name="id" value={c.id} />
                  <input type="hidden" name="action" value="unapprove" />
                  <button type="submit"
                    class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-(--bg-elevated) hover:bg-(--bg-surface) border border-(--border-subtle) text-(--text-secondary) text-xs font-medium rounded-md transition-colors">
                    Visszavonás
                  </button>
                </form>
              )}
              <form method="POST" onsubmit="return confirm('Törlöd ezt a hozzászólást?')">
                <input type="hidden" name="id" value={c.id} />
                <input type="hidden" name="action" value="delete" />
                <button type="submit"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950/30 text-xs font-medium rounded-md transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/>
                  </svg>
                  Törlés
                </button>
              </form>
            </div>
          </div>
        );
      })}
    </div>

  </div>
</AdminLayout>

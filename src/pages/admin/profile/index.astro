---
export const prerender = false;

import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase';

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/admin/login');

type AlertType = { type: 'success' | 'error'; msg: string } | null;
let nameAlert: AlertType = null;
let emailAlert: AlertType = null;
let passwordAlert: AlertType = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action')?.toString();

  if (action === 'name') {
    const username = form.get('username')?.toString().trim() ?? '';
    if (!username) {
      nameAlert = { type: 'error', msg: 'A felhasználónév nem lehet üres.' };
    } else {
      const { error } = await supabase.auth.updateUser({ data: { username } });
      nameAlert = error
        ? { type: 'error', msg: 'Hiba: ' + error.message }
        : { type: 'success', msg: 'Felhasználónév sikeresen frissítve.' };
    }
  }

  if (action === 'email') {
    const newEmail = form.get('email')?.toString().trim() ?? '';
    if (!newEmail) {
      emailAlert = { type: 'error', msg: 'Az email nem lehet üres.' };
    } else {
      const { error } = await supabase.auth.updateUser({ email: newEmail });
      emailAlert = error
        ? { type: 'error', msg: 'Hiba: ' + error.message }
        : { type: 'success', msg: 'Megerősítő email elküldve az új email-re.' };
    }
  }

  if (action === 'password') {
    const currentPassword = form.get('current_password')?.toString() ?? '';
    const password = form.get('password')?.toString() ?? '';
    const confirm = form.get('confirm')?.toString() ?? '';

    if (!currentPassword) {
      passwordAlert = { type: 'error', msg: 'Add meg a jelenlegi jelszót.' };
    } else if (password.length < 6) {
      passwordAlert = { type: 'error', msg: 'Az új jelszó legalább 6 karakter legyen.' };
    } else if (password !== confirm) {
      passwordAlert = { type: 'error', msg: 'A két jelszó nem egyezik.' };
    } else {
      // Re-authenticate with current password first
      const { error: authError } = await supabase.auth.signInWithPassword({
        email: user.email!,
        password: currentPassword,
      });
      if (authError) {
        passwordAlert = { type: 'error', msg: 'Hibás jelenlegi jelszó.' };
      } else {
        const { error } = await supabase.auth.updateUser({ password });
        passwordAlert = error
          ? { type: 'error', msg: 'Hiba: ' + error.message }
          : { type: 'success', msg: 'Jelszó sikeresen megváltoztatva.' };
      }
    }
  }

  const { data: { user: refreshed } } = await supabase.auth.getUser();
  if (refreshed) Object.assign(user, refreshed);
}

// Stats
const [{ count: blogCount }, { count: msgCount }, { count: unreadCount }] = await Promise.all([
  supabase.from('blog_posts').select('*', { count: 'exact', head: true }),
  supabase.from('contact_messages').select('*', { count: 'exact', head: true }),
  supabase.from('contact_messages').select('*', { count: 'exact', head: true }).eq('is_read', false),
]);

const displayName = (user.user_metadata?.username as string | undefined) ?? user.email ?? '';
const avatarLetter = (displayName.charAt(0) || 'A').toUpperCase();

const createdAt = new Date(user.created_at).toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' });
const lastSignIn = user.last_sign_in_at
  ? new Date(user.last_sign_in_at).toLocaleString('hu-HU', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })
  : '–';

const now = new Date();
const hour = now.getHours();
const greeting = hour < 5 ? 'Jó éjt' : hour < 12 ? 'Jó reggelt' : hour < 18 ? 'Jó napot' : 'Jó estét';

const daysSinceCreation = Math.floor((now.getTime() - new Date(user.created_at).getTime()) / 86_400_000);
const todayStr = now.toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });
---

<AdminLayout title="Profil kezelés" activePage="profile">

  <!-- Avatar header -->
  <div class="flex items-center gap-4 mb-6">
    <span class="w-14 h-14 rounded-full bg-(--accent) text-(--on-accent) text-2xl font-bold flex items-center justify-center shrink-0 select-none">
      {avatarLetter}
    </span>
    <div>
      <p class="font-semibold text-(--text-primary)">{displayName}</p>
      <p class="text-sm text-(--text-tertiary)">{user.email}</p>
    </div>
  </div>

  <!-- Greeting card – mobile only -->
  <section class="xl:hidden bg-(--accent-bg) border border-(--accent-border) rounded-lg p-5 mb-6">
    <p class="text-xs text-(--accent) font-medium mb-1">{todayStr}</p>
    <p class="text-lg font-semibold text-(--text-primary)">{greeting}, {displayName.split(' ')[0]}! 👋</p>
    <p class="text-sm text-(--text-secondary) mt-1">
      {daysSinceCreation === 0 ? 'Ma hoztad létre ezt a fiókot.' : daysSinceCreation === 1 ? 'Tegnap óta vagy itt.' : `${daysSinceCreation} napja vagy már itt.`}
    </p>
  </section>

  <div class="grid grid-cols-1 xl:grid-cols-[1fr_320px] gap-6 items-start">

    <!-- Left: forms -->
    <div class="space-y-6">

      <!-- Username -->
      <section class="bg-(--bg-surface) border border-(--border-subtle) rounded-lg p-5 space-y-4">
        <h2 class="text-sm font-semibold text-(--text-primary)">Felhasználónév</h2>
        {nameAlert && (
          <div class={`px-3 py-2.5 rounded-md text-sm border ${nameAlert.type === 'success' ? 'bg-green-50 dark:bg-green-950/30 border-green-200 dark:border-green-800 text-green-700 dark:text-green-400' : 'bg-red-50 dark:bg-red-950/30 border-red-200 dark:border-red-800 text-red-700 dark:text-red-400'}`}>
            {nameAlert.msg}
          </div>
        )}
        <form method="POST" class="flex gap-2">
          <input type="hidden" name="action" value="name" />
          <input type="text" name="username" value={displayName} required
            class="flex-1 px-3 py-2 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md text-sm focus:outline-none focus:border-(--accent) transition" />
          <button type="submit"
            class="px-4 py-2 bg-(--accent) hover:bg-(--accent-bright) text-(--on-accent) text-sm font-medium rounded-md transition-colors shrink-0">
            Mentés
          </button>
        </form>
      </section>

      <!-- Email -->
      <section class="bg-(--bg-surface) border border-(--border-subtle) rounded-lg p-5 space-y-4">
        <h2 class="text-sm font-semibold text-(--text-primary)">Email cím módosítása</h2>
        {emailAlert && (
          <div class={`px-3 py-2.5 rounded-md text-sm border ${emailAlert.type === 'success' ? 'bg-green-50 dark:bg-green-950/30 border-green-200 dark:border-green-800 text-green-700 dark:text-green-400' : 'bg-red-50 dark:bg-red-950/30 border-red-200 dark:border-red-800 text-red-700 dark:text-red-400'}`}>
            {emailAlert.msg}
          </div>
        )}
        <form method="POST" class="flex gap-2">
          <input type="hidden" name="action" value="email" />
          <input type="email" name="email" placeholder={user.email ?? ''} required
            class="flex-1 px-3 py-2 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md text-sm focus:outline-none focus:border-(--accent) transition" />
          <button type="submit"
            class="px-4 py-2 bg-(--accent) hover:bg-(--accent-bright) text-(--on-accent) text-sm font-medium rounded-md transition-colors shrink-0">
            Módosítás
          </button>
        </form>
        <p class="text-xs text-(--text-tertiary)">Megerősítő emailt küldünk az új email-re.</p>
      </section>

      <!-- Password -->
      <section class="bg-(--bg-surface) border border-(--border-subtle) rounded-lg p-5 space-y-4">
        <h2 class="text-sm font-semibold text-(--text-primary)">Jelszó módosítása</h2>
        {passwordAlert && (
          <div class={`px-3 py-2.5 rounded-md text-sm border ${passwordAlert.type === 'success' ? 'bg-green-50 dark:bg-green-950/30 border-green-200 dark:border-green-800 text-green-700 dark:text-green-400' : 'bg-red-50 dark:bg-red-950/30 border-red-200 dark:border-red-800 text-red-700 dark:text-red-400'}`}>
            {passwordAlert.msg}
          </div>
        )}
        <form method="POST" class="space-y-3">
          <input type="hidden" name="action" value="password" />
          <input type="password" name="current_password" placeholder="Jelenlegi jelszó" required
            class="w-full px-3 py-2 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md text-sm focus:outline-none focus:border-(--accent) transition" />
          <div class="border-t border-(--border-subtle) pt-3 space-y-3">
            <input type="password" name="password" placeholder="Új jelszó (min. 6 karakter)" required minlength="6"
              class="w-full px-3 py-2 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md text-sm focus:outline-none focus:border-(--accent) transition" />
            <input type="password" name="confirm" placeholder="Új jelszó megerősítése" required
              class="w-full px-3 py-2 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md text-sm focus:outline-none focus:border-(--accent) transition" />
          </div>
          <button type="submit"
            class="px-4 py-2 bg-(--accent) hover:bg-(--accent-bright) text-(--on-accent) text-sm font-medium rounded-md transition-colors">
            Jelszó módosítása
          </button>
        </form>
      </section>

    </div>

    <!-- Right: info + stats -->
    <div class="space-y-4">

      <!-- Greeting card – desktop only -->
      <section class="hidden xl:block bg-(--accent-bg) border border-(--accent-border) rounded-lg p-5">
        <p class="text-xs text-(--accent) font-medium mb-1">{todayStr}</p>
        <p class="text-lg font-semibold text-(--text-primary)">{greeting}, {displayName.split(' ')[0]}! 👋</p>
        <p class="text-sm text-(--text-secondary) mt-1">
          {daysSinceCreation === 0
            ? 'Ma hoztad létre ezt a fiókot.'
            : daysSinceCreation === 1
            ? 'Tegnap óta vagy itt.'
            : `${daysSinceCreation} napja vagy már itt.`}
        </p>
      </section>

      <!-- Account info -->
      <section class="bg-(--bg-surface) border border-(--border-subtle) rounded-lg p-5 space-y-3">
        <h2 class="text-sm font-semibold text-(--text-primary)">Fiók adatok</h2>
        <dl class="space-y-2.5">
          <div>
            <dt class="text-xs text-(--text-tertiary)">Felhasználó ID</dt>
            <dd class="text-xs font-mono text-(--text-secondary) mt-0.5 break-all">{user.id}</dd>
          </div>
          <div>
            <dt class="text-xs text-(--text-tertiary)">Regisztráció</dt>
            <dd class="text-sm text-(--text-secondary) mt-0.5">{createdAt}</dd>
          </div>
          <div>
            <dt class="text-xs text-(--text-tertiary)">Utolsó bejelentkezés</dt>
            <dd class="text-sm text-(--text-secondary) mt-0.5">{lastSignIn}</dd>
          </div>
          <div>
            <dt class="text-xs text-(--text-tertiary)">Hitelesítési mód</dt>
            <dd class="text-sm text-(--text-secondary) mt-0.5 capitalize">{user.app_metadata?.provider ?? 'email'}</dd>
          </div>
          <div>
            <dt class="text-xs text-(--text-tertiary)">Jogosultsági szint</dt>
            <dd class="mt-0.5">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-(--accent-bg) text-(--accent) border border-(--accent-border)">
                {(user.app_metadata?.role as string | undefined) ?? user.role ?? 'authenticated'}
              </span>
            </dd>
          </div>
        </dl>
      </section>

      <!-- Stats -->
      <section class="bg-(--bg-surface) border border-(--border-subtle) rounded-lg p-5 space-y-3">
        <h2 class="text-sm font-semibold text-(--text-primary)">Statisztikák</h2>
        <div class="space-y-2">
          <a href="/admin/blog/" class="flex items-center justify-between px-3 py-2.5 rounded-md hover:bg-(--bg-elevated) transition-colors group">
            <span class="flex items-center gap-2 text-sm text-(--text-secondary) group-hover:text-(--text-primary) transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
              Blog bejegyzések
            </span>
            <span class="text-sm font-semibold text-(--text-primary)">{blogCount ?? 0}</span>
          </a>
          <a href="/admin/messages/" class="flex items-center justify-between px-3 py-2.5 rounded-md hover:bg-(--bg-elevated) transition-colors group">
            <span class="flex items-center gap-2 text-sm text-(--text-secondary) group-hover:text-(--text-primary) transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
                <path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
              </svg>
              Összes üzenet
            </span>
            <span class="text-sm font-semibold text-(--text-primary)">{msgCount ?? 0}</span>
          </a>
          {(unreadCount ?? 0) > 0 && (
            <a href="/admin/messages/" class="flex items-center justify-between px-3 py-2.5 rounded-md bg-amber-50 dark:bg-amber-950/20 border border-amber-200 dark:border-amber-800/50 hover:bg-amber-100 dark:hover:bg-amber-950/40 transition-colors">
              <span class="flex items-center gap-2 text-sm text-amber-700 dark:text-amber-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                Olvasatlan üzenet
              </span>
              <span class="text-sm font-semibold text-amber-700 dark:text-amber-400">{unreadCount}</span>
            </a>
          )}
        </div>
      </section>

    </div>
  </div>
</AdminLayout>

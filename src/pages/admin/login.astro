---
export const prerender = false;

import '../../styles/global.css';
import { createSupabaseServerClient } from '../../lib/supabase';

const supabase = createSupabaseServerClient(Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (user) return Astro.redirect('/admin/blog/');

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = form.get('email')?.toString() ?? '';
  const password = form.get('password')?.toString() ?? '';

  const { error } = await supabase.auth.signInWithPassword({ email, password });

  if (error) {
    errorMsg = 'Hibás email cím vagy jelszó.';
  } else {
    return Astro.redirect('/admin/blog/');
  }
}
---

<!doctype html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('kl-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin bejelentkezés – levikaldor.hu</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet" />
</head>
<body class="bg-(--bg-base) text-(--text-primary) antialiased font-body min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="mb-8 text-center">
      <a href="/" class="inline-block hover:opacity-75 transition-opacity">
        <img src="/favicon.svg" alt="KL" class="w-12 h-12 mx-auto mb-4" />
      </a>
      <h1 class="text-xl font-bold text-(--text-primary)">Admin bejelentkezés</h1>
      <p class="text-sm text-(--text-secondary) mt-1">levikaldor.hu</p>
    </div>

    <form method="POST" class="bg-(--bg-surface) border border-(--border-subtle) rounded-lg p-6 space-y-4 shadow-(--shadow-md)">
      {errorMsg && (
        <div class="px-3 py-2.5 bg-red-50 dark:bg-red-950/30 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 text-sm rounded-md">
          {errorMsg}
        </div>
      )}
      <div>
        <label for="email" class="block text-sm font-medium text-(--text-secondary) mb-1.5">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email"
          class="w-full px-4 py-3 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md focus:outline-none focus:border-(--accent) transition" />
      </div>
      <div>
        <label for="password" class="block text-sm font-medium text-(--text-secondary) mb-1.5">Jelszó</label>
        <input type="password" id="password" name="password" required autocomplete="current-password"
          class="w-full px-4 py-3 bg-white dark:bg-(--bg-elevated) border border-(--border-subtle) text-(--text-primary) rounded-md focus:outline-none focus:border-(--accent) transition" />
      </div>
      <button type="submit"
        class="w-full py-3 bg-(--accent) hover:bg-(--accent-bright) active:bg-(--accent-dim) text-white font-semibold rounded-md transition-colors">
        Bejelentkezés
      </button>
    </form>

    <p class="text-center mt-6 text-xs text-(--text-tertiary)">
      <a href="/" class="hover:text-(--accent) transition-colors">← Vissza a főoldalra</a>
    </p>
  </div>
</body>
</html>
